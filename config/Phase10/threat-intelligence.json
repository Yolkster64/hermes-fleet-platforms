  "heuristicRules": {
    "version": "1.0.0",
    "rules": [
      {
        "id": "H001",
        "name": "Registry Modification Heuristic",
        "description": "Detects suspicious registry modifications",
        "riskScore": 0.75,
        "enabled": true,
        "conditions": [
          "RegSetValueEx",
          "RegCreateKeyEx",
          "HKLM\\System\\CurrentControlSet\\Services"
        ]
      },
      {
        "id": "H002",
        "name": "Network Connection Heuristic",
        "description": "Detects suspicious network connections",
        "riskScore": 0.65,
        "enabled": true,
        "conditions": [
          "WSASocket",
          "ConnectEx",
          "InternetConnect",
          "suspicious_port"
        ]
      },
      {
        "id": "H003",
        "name": "Process Injection Heuristic",
        "description": "Detects process injection attempts",
        "riskScore": 0.85,
        "enabled": true,
        "conditions": [
          "CreateRemoteThread",
          "WriteProcessMemory",
          "VirtualAllocEx",
          "SetWindowsHookEx"
        ]
      },
      {
        "id": "H004",
        "name": "File System Modification Heuristic",
        "description": "Detects suspicious file system modifications",
        "riskScore": 0.70,
        "enabled": true,
        "conditions": [
          "CreateFileA",
          "WriteFile",
          "DeleteFileA",
          "system_directory_write"
        ]
      }
    ]
  },
  "behaviorPatterns": {
    "version": "1.0.0",
    "patterns": [
      {
        "id": "BP001",
        "name": "Encryption Loop Pattern",
        "description": "Detects file encryption behavior typical of ransomware",
        "confidence": 0.9,
        "indicators": [
          "file_access",
          "encryption_api_calls",
          "file_writes",
          "file_deletion"
        ],
        "severity": "Critical"
      },
      {
        "id": "BP002",
        "name": "Command & Control Pattern",
        "description": "Detects C&C communication behavior",
        "confidence": 0.85,
        "indicators": [
          "network_connect",
          "dns_query",
          "http_request",
          "outbound_connection"
        ],
        "severity": "High"
      },
      {
        "id": "BP003",
        "name": "Credential Theft Pattern",
        "description": "Detects credential harvesting behavior",
        "confidence": 0.80,
        "indicators": [
          "registry_read",
