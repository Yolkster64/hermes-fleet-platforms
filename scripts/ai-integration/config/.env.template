# AI Integration Environment Configuration Template
# Copy this file to .env and fill in your actual API keys and settings

# ============================================================================
# OpenAI ChatGPT Pro Configuration
# ============================================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7
OPENAI_REQUEST_TIMEOUT=60

# ============================================================================
# Codex Configuration
# ============================================================================
CODEX_API_KEY=your_codex_api_key_here
CODEX_ENGINE=code-davinci-002
CODEX_API_BASE=https://api.openai.com/v1
CODEX_MAX_TOKENS=2048
CODEX_TEMPERATURE=0.5
CODEX_REQUEST_TIMEOUT=60

# ============================================================================
# AI Coordination Settings
# ============================================================================
AI_COORDINATION_ENABLED=true
AI_CONFLICT_DETECTION=true
AI_AUTO_APPROVAL_ENABLED=false
AI_CHANGE_TRACKING=true
AI_AUDIT_LOG_PATH=./config/audit-log.json
AI_VERSION_HISTORY_LIMIT=50

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
OPENAI_RATE_LIMIT=60
OPENAI_RATE_LIMIT_WINDOW=60
CODEX_RATE_LIMIT=50
CODEX_RATE_LIMIT_WINDOW=60
ENABLE_RATE_LIMITING=true

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_MAX_SIZE=10485760
LOG_RETENTION_DAYS=30
SANITIZE_LOGS=true
LOG_API_CALLS=true

# ============================================================================
# Build Configuration Integration
# ============================================================================
BUILD_CONFIG_PATH=./build-config.json
HELIOS_ARCHITECTURE_VERSION=1.0
PROJECT_CONTEXT_FILE=./project-context.md

# ============================================================================
# Dry-Run Mode
# ============================================================================
DRY_RUN=false
DRY_RUN_VERBOSE=true

# ============================================================================
# Proxy Configuration (if needed)
# ============================================================================
PROXY_ENABLED=false
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# ============================================================================
# Development Settings
# ============================================================================
DEBUG_MODE=false
ENABLE_TELEMETRY=true
CACHE_RESPONSES=true
CACHE_TTL=3600
