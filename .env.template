# API Keys for HELIOS AI Services
# IMPORTANT: Never commit this file to Git!
# This file is in .gitignore and should be kept private

# ============================================================================
# ChatGPT Pro (GPT-4)
# Get key at: https://platform.openai.com/account/api-keys
# ============================================================================
export CHATGPT_API_KEY="sk-YOUR_CHATGPT_KEY_HERE"
export CHATGPT_MODEL="gpt-4"
export CHATGPT_ENABLED=true

# ============================================================================
# Codex
# Get key at: https://platform.openai.com/account/api-keys
# ============================================================================
export CODEX_API_KEY="sk-YOUR_CODEX_KEY_HERE"
export CODEX_MODEL="code-davinci-002"
export CODEX_TEMPERATURE=0.2
export CODEX_ENABLED=true

# ============================================================================
# GPT-4.5 (Latest Model)
# Get key at: https://platform.openai.com/account/api-keys
# ============================================================================
export GPT45_API_KEY="sk-YOUR_GPT45_KEY_HERE"
export GPT45_MODEL="gpt-4-turbo-2024-04"
export GPT45_ENABLED=true

# ============================================================================
# Cost Limits (USD per month)
# ============================================================================
export COST_LIMIT_TOTAL=300
export COST_LIMIT_CHATGPT=100
export COST_LIMIT_CODEX=50
export COST_LIMIT_GPT45=150

# ============================================================================
# Rate Limiting
# ============================================================================
export RATE_LIMIT_REQUESTS_PER_MINUTE=30
export RATE_LIMIT_REQUESTS_PER_DAY=500

# ============================================================================
# Hub Configuration
# ============================================================================
export AI_HUB_DEBUG=false
export AI_HUB_DRY_RUN=false
export AI_HUB_AUTO_APPROVE_THRESHOLD=0.95
export AI_HUB_CONFLICT_STRATEGY="consensus"

# ============================================================================
# Setup Instructions
# ============================================================================
# 1. Get your API keys from https://platform.openai.com/account/api-keys
# 2. Replace the placeholder values above with your actual keys
# 3. Run: source .env (on Unix/Mac/WSL) or copy values to PowerShell profile (Windows)
# 4. Verify: .\scripts\ai-services\validate-keys.ps1
# 5. Test: .\scripts\ai-services\test-services.ps1
