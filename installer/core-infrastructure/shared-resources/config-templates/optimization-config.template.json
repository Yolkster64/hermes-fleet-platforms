{
  "version": "1.0.0",
  "optimization": {
    "profiles": [
      {
        "name": "cost-optimized",
        "description": "Minimize costs, accept longer latency",
        "settings": {
          "preferredModels": [
            "claude-3-haiku",
            "gpt-3.5-turbo",
            "mistral-7b"
          ],
          "maxCostPerRequest": 0.01,
          "timeout": 60000,
          "parallelism": 2,
          "cacheResults": true,
          "cacheTTL": 3600
        }
      },
      {
        "name": "speed-optimized",
        "description": "Minimize latency, accept higher cost",
        "settings": {
          "preferredModels": [
            "gpt-4-turbo",
            "claude-3-opus",
            "gemini-pro"
          ],
          "maxCostPerRequest": 0.50,
          "timeout": 5000,
          "parallelism": 8,
          "cacheResults": false,
          "cacheTTL": 0
        }
      },
      {
        "name": "quality-optimized",
        "description": "Maximize accuracy, balance cost/speed",
        "settings": {
          "preferredModels": [
            "gpt-4-turbo",
            "claude-3-opus",
            "gpt-4"
          ],
          "maxCostPerRequest": 0.25,
          "timeout": 30000,
          "parallelism": 4,
          "cacheResults": true,
          "cacheTTL": 1800,
          "useEnsemble": true
        }
      },
      {
        "name": "balanced",
        "description": "Balance all factors",
        "settings": {
          "preferredModels": [
            "gpt-4-turbo",
            "claude-3-sonnet",
            "gpt-3.5-turbo"
          ],
          "maxCostPerRequest": 0.10,
          "timeout": 15000,
          "parallelism": 4,
          "cacheResults": true,
          "cacheTTL": 900
        }
      },
      {
        "name": "scale-optimized",
        "description": "Handle high volume with distributed processing",
        "settings": {
          "preferredModels": [
            "gpt-3.5-turbo",
            "claude-3-haiku"
          ],
          "maxCostPerRequest": 0.02,
          "timeout": 45000,
          "parallelism": 16,
          "cacheResults": true,
          "cacheTTL": 7200,
          "useLoadBalancing": true,
          "circuitBreaker": true
        }
      }
    ],
    "activeProfile": "balanced"
  },
  "resourceAllocation": {
    "cpu": {
      "reserved": 2,
      "maximum": 8,
      "unit": "cores"
    },
    "memory": {
      "reserved": 4,
      "maximum": 16,
      "unit": "GB"
    },
    "storage": {
      "cache": 10,
      "logs": 50,
      "data": 100,
      "unit": "GB"
    },
    "network": {
      "bandwidth": 100,
      "unit": "Mbps"
    }
  },
  "costManagement": {
    "budgets": {
      "daily": 50.00,
      "monthly": 1000.00,
      "quarterly": 3000.00
    },
    "alerts": {
      "enabledAt": 0.80,
      "warningAt": 0.90,
      "criticalAt": 0.95
    },
    "reportingFrequency": "daily",
    "costOptimizationStrategies": [
      "model-selection",
      "request-caching",
      "batch-processing",
      "result-reuse"
    ]
  },
  "performance": {
    "metrics": [
      {
        "name": "latency",
        "target": 1000,
        "unit": "ms",
        "percentile": 95
      },
      {
        "name": "throughput",
        "target": 100,
        "unit": "requests/sec"
      },
      {
        "name": "availability",
        "target": 0.999,
        "unit": "percentage"
      },
      {
        "name": "errorRate",
        "target": 0.01,
        "unit": "percentage"
      }
    ],
    "monitoring": {
      "enabled": true,
      "samplingRate": 1.0,
      "aggregationInterval": 60
    }
  },
  "scalability": {
    "horizontalScaling": {
      "enabled": true,
      "minInstances": 1,
      "maxInstances": 10,
      "scaleUpThreshold": 0.80,
      "scaleDownThreshold": 0.30,
      "cooldownPeriod": 300
    },
    "verticalScaling": {
      "enabled": false,
      "maxCpuCores": 8,
      "maxMemoryGB": 32
    },
    "batchProcessing": {
      "enabled": true,
      "batchSize": 50,
      "maxQueueSize": 5000
    }
  },
  "caching": {
    "enabled": true,
    "strategy": "multilevel",
    "levels": [
      {
        "name": "memory",
        "ttl": 300,
        "maxSize": 1000
      },
      {
        "name": "redis",
        "ttl": 3600,
        "maxSize": 100000
      },
      {
        "name": "disk",
        "ttl": 86400,
        "maxSize": 1000000
      }
    ],
    "invalidationStrategy": "time-based"
  },
  "quality": {
    "targetAccuracy": 0.95,
    "validationEnabled": true,
    "testingEnabled": true,
    "abtesting": {
      "enabled": false,
      "trafficSplit": 0.50
    }
  },
  "scheduling": {
    "backgroundJobs": {
      "enabled": true,
      "maxConcurrent": 5
    },
    "maintenance": {
      "enabled": true,
      "schedule": "0 2 * * *",
      "tasks": [
        "cache-cleanup",
        "log-rotation",
        "db-optimization"
      ]
    }
  }
}
