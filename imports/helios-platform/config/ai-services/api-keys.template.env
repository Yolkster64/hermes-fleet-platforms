# AI Services Configuration Template
# Copy this file to api-keys.env and fill in your actual API keys

# OpenAI API Keys
OPENAI_API_KEY_CHATGPT_PRO=your_chatgpt_pro_api_key_here
OPENAI_API_KEY_CODEX=your_codex_api_key_here
OPENAI_API_KEY_GPT45=your_gpt45_api_key_here

# Optional: Single API key for all OpenAI services
OPENAI_API_KEY=your_openai_api_key_here

# Azure OpenAI (Alternative provider)
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_ENDPOINT=

# Service Organization IDs
OPENAI_ORG_ID=your_organization_id

# Proxy Configuration (Optional)
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=localhost,127.0.0.1

# Logging Configuration
LOG_LEVEL=Info
LOG_PATH=C:\Users\ADMIN\helios-platform\logs\ai-services

# Cost Management
DAILY_BUDGET_LIMIT=50
MONTHLY_BUDGET_LIMIT=500

# Rate Limiting
REQUESTS_PER_MINUTE=60
REQUESTS_PER_HOUR=1000
