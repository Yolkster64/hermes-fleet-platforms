<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="MonadoBlade.GUI.Systems.FpsCounter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="White"
             FontFamily="Consolas"
             FontSize="12">
    <Grid Margin="10">
        <StackPanel>
            <!-- FPS Display -->
            <Border Background="#2C3E50" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="FPS COUNTER" FontSize="14" FontWeight="Bold" Foreground="#ECF0F1"/>
                    
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Current FPS -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CURRENT" Foreground="#95A5A6" FontSize="10"/>
                            <TextBlock x:Name="CurrentFpsText" Text="0" Foreground="#3498DB" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>

                        <!-- Average FPS -->
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="AVERAGE" Foreground="#95A5A6" FontSize="10"/>
                            <TextBlock x:Name="AvgFpsText" Text="0" Foreground="#2ECC71" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>

                        <!-- Min/Max -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="MIN / MAX" Foreground="#95A5A6" FontSize="10"/>
                            <TextBlock x:Name="MinMaxFpsText" Text="0 / 0" Foreground="#E74C3C" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <!-- Frame Time -->
                    <TextBlock Margin="0,8,0,0" Foreground="#95A5A6" FontSize="10">
                        Frame Time: <Run x:Name="FrameTimeText" Foreground="#3498DB" FontWeight="Bold">0</Run> ms
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- History Graph -->
            <Border Background="#2C3E50" CornerRadius="5" Padding="10" Height="120">
                <Grid>
                    <Canvas x:Name="FpsHistoryCanvas" Background="#1A252F"/>
                    <TextBlock Text="FPS History (60 frames)" VerticalAlignment="Top" Foreground="#95A5A6" FontSize="10" Margin="5"/>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
