<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="MonadoBlade.GUI.Systems.MemoryProfiler"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="White"
             FontFamily="Consolas"
             FontSize="12">
    <Grid Margin="10">
        <StackPanel Orientation="Vertical" Spacing="10">
            <!-- Header -->
            <Border Background="#2C3E50" CornerRadius="5" Padding="10">
                <TextBlock Text="MEMORY PROFILER" FontSize="14" FontWeight="Bold" Foreground="#ECF0F1"/>
            </Border>

            <!-- Current Memory Stats -->
            <Border Background="#2C3E50" CornerRadius="5" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="WORKING SET" Foreground="#95A5A6" FontSize="10"/>
                        <TextBlock x:Name="WorkingSetText" Text="0 MB" Foreground="#3498DB" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="MANAGED" Foreground="#95A5A6" FontSize="10"/>
                        <TextBlock x:Name="ManagedText" Text="0 MB" Foreground="#2ECC71" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="NATIVE" Foreground="#95A5A6" FontSize="10"/>
                        <TextBlock x:Name="NativeText" Text="0 MB" Foreground="#E74C3C" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Memory Usage Bar -->
            <Border Background="#2C3E50" CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="MEMORY DISTRIBUTION" Foreground="#95A5A6" FontSize="10"/>
                    <Grid Height="30" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="ManagedColumn" Width="30*"/>
                            <ColumnDefinition x:Name="NativeColumn" Width="20*"/>
                            <ColumnDefinition x:Name="FreeColumn" Width="50*"/>
                        </Grid.ColumnDefinitions>

                        <Rectangle Grid.Column="0" Fill="#2ECC71" Radius="3"/>
                        <Rectangle Grid.Column="1" Fill="#E74C3C" Margin="2,0,0,0" Radius="3"/>
                        <Rectangle Grid.Column="2" Fill="#34495E" Margin="2,0,0,0" Radius="3"/>
                    </Grid>
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Managed" FontSize="9" Foreground="#2ECC71"/>
                        <TextBlock Grid.Column="1" Text="Native" FontSize="9" Foreground="#E74C3C"/>
                        <TextBlock Grid.Column="2" Text="Free" FontSize="9" Foreground="#34495E" TextAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- GC Statistics -->
            <Border Background="#2C3E50" CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="GC STATISTICS" FontSize="12" FontWeight="Bold" Foreground="#ECF0F1" Margin="0,0,0,8"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Collections" Foreground="#95A5A6" FontSize="9"/>
                            <TextBlock x:Name="GcCollectionsText" Text="0" Foreground="#F39C12" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Peak Memory" Foreground="#95A5A6" FontSize="9"/>
                            <TextBlock x:Name="PeakMemoryText" Text="0 MB" Foreground="#F39C12" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Memory History Graph -->
            <Border Background="#2C3E50" CornerRadius="5" Padding="10" Height="100">
                <Grid>
                    <Canvas x:Name="MemoryHistoryCanvas" Background="#1A252F"/>
                    <TextBlock Text="Memory History" VerticalAlignment="Top" Foreground="#95A5A6" FontSize="10" Margin="5"/>
                </Grid>
            </Border>

            <!-- Alerts -->
            <Border x:Name="AlertBorder" Background="Transparent" CornerRadius="5" Padding="10" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠️" FontSize="16" Margin="0,0,10,0"/>
                    <TextBlock x:Name="AlertText" Text="Memory usage above threshold" Foreground="#E74C3C" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
