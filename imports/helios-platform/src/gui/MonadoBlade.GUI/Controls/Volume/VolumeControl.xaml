<Window
    x:Class="MonadoBlade.GUI.Controls.Volume.VolumeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Width="400"
    Height="120"
    Background="Transparent"
    WindowStyle="None"
    AllowsTransparency="True"
    ShowInTaskbar="False"
    Topmost="True">

    <Grid Background="#1F1F1F" CornerRadius="12">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="20">
            <!-- Title -->
            <TextBlock
                Text="Volume"
                Foreground="#E0E0E0"
                FontSize="14"
                FontWeight="SemiBold"
                Margin="0,0,0,10" />

            <!-- Volume Slider with Gradient -->
            <Grid Height="40">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00D4FF" Offset="0.0" />
                        <GradientStop Color="#7F4FFF" Offset="0.5" />
                        <GradientStop Color="#FF1493" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.OpacityMask>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Black" Offset="0.0" />
                        <GradientStop Color="Black" Offset="0.85" />
                        <GradientStop Color="Transparent" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.OpacityMask>

                <Slider
                    x:Name="VolumeSlider"
                    Minimum="0"
                    Maximum="100"
                    Value="50"
                    VerticalAlignment="Center"
                    Margin="0"
                    Foreground="Transparent"
                    Background="Transparent"
                    ValueChanged="VolumeSlider_ValueChanged"
                    PreviewKeyDown="VolumeSlider_PreviewKeyDown" />
            </Grid>

            <!-- Volume Level Display -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Space-Between" Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Text="Level: "
                        Foreground="#B0B0B0"
                        FontSize="12" />
                    <TextBlock
                        x:Name="VolumeLevelText"
                        Text="50%"
                        Foreground="#00D4FF"
                        FontSize="12"
                        FontWeight="Bold" />
                </StackPanel>

                <TextBlock
                    x:Name="MuteIndicator"
                    Text="🔊"
                    Foreground="#00D4FF"
                    FontSize="14"
                    VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <!-- Glow Effect -->
        <Grid.Effect>
            <DropShadowEffect
                Color="#00D4FF"
                BlurRadius="15"
                ShadowDepth="0"
                Opacity="0.3" />
        </Grid.Effect>
    </Grid>
</Window>
