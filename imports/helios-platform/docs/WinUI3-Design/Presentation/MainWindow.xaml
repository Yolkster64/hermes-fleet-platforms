<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HELIOS.Platform.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HELIOS.Platform"
    Title="HELIOS Platform"
    ExtendsContentIntoTitleBar="True"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid x:Name="RootGrid" Background="#0D0D0D">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Title Bar -->
        <Grid x:Name="TitleBar" Grid.ColumnSpan="2" Height="48" Background="#1A1A1A" Padding="16,0" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                <TextBlock Text="⚡ HELIOS" Foreground="#00D9FF" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
                <TextBlock x:Name="TitleText" Text="Enterprise Management System" Foreground="#A0A0A0" FontSize="14" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Navigation Rail (Left Sidebar) -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            Grid.Column="0"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True"
            Background="#1A1A1A"
            ItemInvoked="NavView_ItemInvoked">

            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Home" Content="Dashboard" Tag="dashboard" />
                <NavigationViewItem Icon="Settings" Content="System Management" Tag="system" />
                <NavigationViewItem Icon="Sync" Content="AI Hub" Tag="ai" />
                <NavigationViewItem Icon="List" Content="Tools" Tag="tools" />
                <NavigationViewItemSeparator />
                <NavigationViewItem Icon="Setting" Content="Settings" Tag="settings" />
                <NavigationViewItem Icon="Help" Content="Help &amp; Support" Tag="help" />
            </NavigationView.MenuItems>

            <!-- Main Content Area -->
            <Grid Grid.Row="1" Grid.Column="1" Padding="24">
                <Frame x:Name="ContentFrame" />
            </Grid>
        </NavigationView>
    </Grid>
</Window>
