<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HELIOS.Platform.Presentation.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0D0D0D">

    <ScrollViewer>
        <StackPanel Spacing="20" Padding="20">
            <!-- Welcome Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Welcome to HELIOS" FontSize="28" FontWeight="Bold" Foreground="#00D9FF" />
                <TextBlock Text="Real-time system monitoring and enterprise management" FontSize="14" Foreground="#A0A0A0" />
            </StackPanel>

            <!-- System Status Grid -->
            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <!-- CPU Card -->
                <Border Grid.Column="0" Background="#1A1A1A" BorderBrush="#303030" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="CPU Usage" FontSize="12" Foreground="#A0A0A0" TextTransform="Uppercase" />
                        <TextBlock x:Name="CpuValue" Text="--" FontSize="32" FontWeight="Bold" Foreground="#00D9FF" />
                        <ProgressBar x:Name="CpuProgress" Maximum="100" Height="4" CornerRadius="2" Background="#303030" />
                    </StackPanel>
                </Border>

                <!-- Memory Card -->
                <Border Grid.Column="1" Background="#1A1A1A" BorderBrush="#303030" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Memory Usage" FontSize="12" Foreground="#A0A0A0" TextTransform="Uppercase" />
                        <TextBlock x:Name="MemoryValue" Text="-- MB" FontSize="32" FontWeight="Bold" Foreground="#00D9FF" />
                        <ProgressBar x:Name="MemoryProgress" Maximum="8192" Height="4" CornerRadius="2" Background="#303030" />
                    </StackPanel>
                </Border>

                <!-- Disk Card -->
                <Border Grid.Column="2" Background="#1A1A1A" BorderBrush="#303030" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Disk Usage" FontSize="12" Foreground="#A0A0A0" TextTransform="Uppercase" />
                        <TextBlock x:Name="DiskValue" Text="--%"  FontSize="32" FontWeight="Bold" Foreground="#00D9FF" />
                        <ProgressBar x:Name="DiskProgress" Maximum="100" Height="4" CornerRadius="2" Background="#303030" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Services Status -->
            <Border Background="#1A1A1A" BorderBrush="#303030" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Active Services" FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF" />
                    <TextBlock x:Name="ServiceCount" Text="Loading..." Foreground="#00D9FF" FontSize="18" />
                    <TextBlock Text="System Uptime" FontSize="12" Foreground="#A0A0A0" Margin="0,12,0,0" TextTransform="Uppercase" />
                    <TextBlock x:Name="UptimeValue" Text="--" FontSize="16" Foreground="#00C4A0" />
                </StackPanel>
            </Border>

            <!-- Quick Actions -->
            <StackPanel Spacing="8">
                <TextBlock Text="Quick Actions" FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="🔄 Refresh" Background="#00D9FF" Foreground="#0D0D0D" Padding="16,8" CornerRadius="4" Click="RefreshButton_Click" />
                    <Button Content="⚙️ Optimize" Background="#FF6B35" Foreground="#FFFFFF" Padding="16,8" CornerRadius="4" />
                    <Button Content="🛡️ Security Scan" Background="#00C4A0" Foreground="#0D0D0D" Padding="16,8" CornerRadius="4" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
