{
  "ai_services": {
    "enabled": true,
    "hub_version": "1.0.0",
    "default_service": "smart_route"
  },
  
  "services": {
    "chatgpt_pro": {
      "name": "ChatGPT Pro (GPT-4)",
      "provider": "OpenAI",
      "model": "gpt-4",
      "enabled": true,
      "api_key_env": "CHATGPT_API_KEY",
      "base_url": "https://api.openai.com/v1",
      "timeout_seconds": 120,
      "best_for": [
        "code_review",
        "code_analysis",
        "optimization_suggestions",
        "documentation_generation",
        "strategic_planning"
      ],
      "temperature": 0.7,
      "max_tokens": 4096,
      "rate_limit_per_minute": 30,
      "rate_limit_per_day": 500,
      "cost_per_1k_tokens_input": 0.03,
      "cost_per_1k_tokens_output": 0.06
    },
    
    "codex": {
      "name": "Codex",
      "provider": "OpenAI",
      "model": "code-davinci-002",
      "enabled": true,
      "api_key_env": "CODEX_API_KEY",
      "base_url": "https://api.openai.com/v1",
      "timeout_seconds": 90,
      "best_for": [
        "code_generation",
        "code_refactoring",
        "test_creation",
        "implementation",
        "snippet_generation"
      ],
      "temperature": 0.2,
      "max_tokens": 2048,
      "rate_limit_per_minute": 60,
      "rate_limit_per_day": 1000,
      "cost_per_1k_tokens": 0.02
    },
    
    "gpt_4_5": {
      "name": "GPT-4.5 (Latest Model)",
      "provider": "OpenAI",
      "model": "gpt-4-turbo-2024-04",
      "enabled": true,
      "api_key_env": "GPT45_API_KEY",
      "base_url": "https://api.openai.com/v1",
      "timeout_seconds": 180,
      "best_for": [
        "complex_analysis",
        "architectural_decisions",
        "multi_component_reasoning",
        "problem_solving",
        "design_generation"
      ],
      "temperature": 0.8,
      "max_tokens": 8192,
      "rate_limit_per_minute": 20,
      "rate_limit_per_day": 300,
      "cost_per_1k_tokens_input": 0.01,
      "cost_per_1k_tokens_output": 0.03
    }
  },
  
  "service_router": {
    "enabled": true,
    "strategy": "confidence_weighted",
    "task_routing": {
      "code_generation": {
        "primary": "codex",
        "primary_weight": 0.9,
        "secondary": "gpt_4_5",
        "secondary_weight": 0.1
      },
      "code_refactoring": {
        "primary": "codex",
        "primary_weight": 0.85,
        "secondary": "gpt_4_5",
        "secondary_weight": 0.15
      },
      "test_creation": {
        "primary": "codex",
        "primary_weight": 0.8,
        "secondary": "gpt_4_5",
        "secondary_weight": 0.2
      },
      "code_review": {
        "primary": "chatgpt_pro",
        "primary_weight": 0.7,
        "secondary": "gpt_4_5",
        "secondary_weight": 0.3
      },
      "documentation_generation": {
        "primary": "chatgpt_pro",
        "primary_weight": 0.75,
        "secondary": "codex",
        "secondary_weight": 0.25
      },
      "optimization_suggestions": {
        "primary": "chatgpt_pro",
        "primary_weight": 0.6,
        "secondary": "gpt_4_5",
        "secondary_weight": 0.4
      },
      "bug_detection": {
        "primary": "chatgpt_pro",
        "primary_weight": 0.65,
        "secondary": "gpt_4_5",
        "secondary_weight": 0.35
      },
      "security_analysis": {
        "primary": "chatgpt_pro",
        "primary_weight": 0.7,
        "secondary": "gpt_4_5",
        "secondary_weight": 0.3
      },
      "architecture_design": {
        "primary": "gpt_4_5",
        "primary_weight": 0.8,
        "secondary": "chatgpt_pro",
        "secondary_weight": 0.2
      },
      "component_analysis": {
        "primary": "gpt_4_5",
        "primary_weight": 0.75,
        "secondary": "chatgpt_pro",
        "secondary_weight": 0.25
      },
      "conflict_resolution": {
        "primary": "gpt_4_5",
        "primary_weight": 0.8,
        "secondary": "chatgpt_pro",
        "secondary_weight": 0.2
      },
      "build_optimization": {
        "primary": "chatgpt_pro",
        "primary_weight": 0.6,
        "secondary": "gpt_4_5",
        "secondary_weight": 0.4
      }
    }
  },
  
  "cost_management": {
    "enabled": true,
    "tracking_enabled": true,
    "cost_limits": {
      "total_monthly_usd": 300,
      "chatgpt_pro_usd": 100,
      "codex_usd": 50,
      "gpt_4_5_usd": 150
    },
    "cost_warning_threshold_percent": 80,
    "cost_limit_action": "pause_requests",
    "track_daily": true,
    "track_by_task": true,
    "track_by_service": true
  },
  
  "rate_limiting": {
    "enabled": true,
    "global_per_minute": 30,
    "global_per_day": 500,
    "per_service_override": true,
    "queue_strategy": "fifo",
    "retry_on_limit": true,
    "retry_attempts": 3,
    "retry_backoff_seconds": 10
  },
  
  "conflict_resolution": {
    "enabled": true,
    "strategy": "consensus",
    "min_services_for_consensus": 2,
    "min_agreement_percent": 75,
    "when_conflicted": "ask_user",
    "auto_approve_threshold": 0.95,
    "log_conflicts": true
  },
  
  "security": {
    "api_key_encryption": true,
    "sanitize_logs": true,
    "sanitize_audit_trail": true,
    "mask_sensitive_data": true,
    "require_approval_for_risky_tasks": true,
    "enable_rollback": true,
    "audit_all_changes": true
  },
  
  "audit": {
    "enabled": true,
    "log_all_requests": true,
    "log_all_responses": true,
    "log_approval_decisions": true,
    "log_changes_made": true,
    "retention_days": 90,
    "storage_location": "audit-logs/"
  },
  
  "fallback": {
    "enabled": true,
    "strategy": "sequential",
    "max_fallback_depth": 3,
    "fallback_on_timeout": true,
    "fallback_on_error": true,
    "fallback_on_rate_limit": true,
    "fallback_on_cost_limit": true
  },
  
  "notifications": {
    "enabled": true,
    "notify_on_approval_needed": true,
    "notify_on_error": true,
    "notify_on_cost_threshold": true,
    "notify_on_conflict": true,
    "notification_methods": ["console", "file"],
    "log_file": "logs/ai-notifications.log"
  },
  
  "features": {
    "enable_dry_run": true,
    "enable_preview_mode": true,
    "enable_consensus_mode": true,
    "enable_smart_routing": true,
    "enable_cost_tracking": true,
    "enable_performance_metrics": true,
    "enable_audit_trail": true,
    "enable_change_tracking": true,
    "enable_automatic_rollback": true
  },
  
  "debug": {
    "enabled": false,
    "verbose_logging": false,
    "log_api_calls": false,
    "log_responses": false,
    "log_file": "logs/debug.log"
  }
}
