{
  "id": "com.helios.plugins.metrics",
  "version": "1.0.0",
  "name": "HELIOS Metrics",
  "description": "System metrics and monitoring plugin. Tracks performance metrics, resource usage, and generates reports.",
  "author": "HELIOS Team",
  "license": "MIT",
  "homepage": "https://helios.dev/plugins/metrics",
  "repository": "https://github.com/helios-platform/plugin-metrics",
  "main": "MetricsPlugin.dll",
  "entryPoint": "HELIOS.Platform.Plugins.Samples.MetricsPlugin",
  "dependencies": [
    {
      "id": "com.helios.plugins.log",
      "version": "^1.0.0",
      "optional": false
    }
  ],
  "capabilities": [
    "metrics",
    "monitoring",
    "performance-tracking",
    "statistics"
  ],
  "priority": 2,
  "autoStart": true,
  "metadata": {
    "category": "monitoring",
    "tags": ["metrics", "performance", "monitoring"],
    "collection_interval_seconds": 5,
    "retention_days": 90,
    "aggregation_level": "detailed"
  }
}
