# EditorConfig for Helios Platform
# Helps maintain consistent coding styles across different editors and IDEs

root = true

# All files
[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Python files
[*.py]
indent_size = 4
max_line_length = 100

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
insert_final_newline = false

# Makefiles
[Makefile]
indent_style = tab

# Shell scripts
[*.sh]
indent_size = 4

# PowerShell
[*.ps1]
indent_size = 4

# XML
[*.xml]
indent_size = 2

# SQL
[*.sql]
indent_size = 2

# Docker
[Dockerfile*]
indent_size = 2

# Terraform
[*.tf]
indent_size = 2
