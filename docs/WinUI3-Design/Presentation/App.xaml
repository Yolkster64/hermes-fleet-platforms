<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="HELIOS.Platform.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HELIOS.Platform">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Fluent Design System -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Custom Theme -->
                <ResourceDictionary Source="Presentation/Themes/HELIOSTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- HELIOS Color Palette -->
            <Color x:Key="HELIOSPrimary">#1F1F1F</Color>
            <Color x:Key="HELIOSSecondary">#00D9FF</Color>
            <Color x:Key="HELIOSAccent">#FF6B35</Color>
            <Color x:Key="HELIOSSuccess">#00C4A0</Color>
            <Color x:Key="HELIOSWarning">#FFB81C</Color>
            <Color x:Key="HELIOSError">#FF3B30</Color>
            <Color x:Key="HELIOSBackground">#0D0D0D</Color>
            <Color x:Key="HELIOSCardBackground">#1A1A1A</Color>
            <Color x:Key="HELIOSBorder">#303030</Color>

            <!-- Typography -->
            <FontFamily x:Key="HELIOSFontFamily">Segoe UI Variable, Segoe UI</FontFamily>
            <x:Double x:Key="HELIOSTitleFontSize">28</x:Double>
            <x:Double x:Key="HELIOSHeadingFontSize">20</x:Double>
            <x:Double x:Key="HELIOSBodyFontSize">14</x:Double>
            <x:Double x:Key="HELIOSCaptionFontSize">12</x:Double>

            <!-- Spacing -->
            <Thickness x:Key="HELIOSPadding">16</Thickness>
            <Thickness x:Key="HELIOSSmallPadding">8</Thickness>
            <Thickness x:Key="HELIOSLargePadding">24</Thickness>

            <!-- Shadows -->
            <Thickness x:Key="HELIOSElevation">0,1,0,3</Thickness>
        </ResourceDictionary>
    </Application.Resources>
</Application>
