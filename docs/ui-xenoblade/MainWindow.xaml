<Window x:Class="HELIOS.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HELIOS - Xenoblade System Monitor"
        Width="1400"
        Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#0A0E27"
        Foreground="#F5F5F5"
        AllowsTransparency="False"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme/Colors.xaml"/>
                <ResourceDictionary Source="Theme/Brushes.xaml"/>
                <ResourceDictionary Source="Theme/Styles.xaml"/>
                <ResourceDictionary Source="Theme/Animations.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource DarkSlateBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" 
                Background="{StaticResource BackgroundSecondaryBrush}"
                BorderBrush="{StaticResource MonadoCyanBrush}"
                BorderThickness="0,0,0,2">
            <Border.Effect>
                <DropShadowEffect Color="#00D4FF" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>

            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <TextBlock Grid.Column="0"
                          Text="⚔ HELIOS"
                          Foreground="{StaticResource MonadoCyanBrush}"
                          FontSize="32"
                          FontWeight="Bold"
                          VerticalAlignment="Center"/>

                <!-- Title -->
                <TextBlock Grid.Column="1"
                          Text="Xenoblade Chronicles System Monitor - Monado Ascendance Protocol"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="14"
                          VerticalAlignment="Center"
                          Margin="40,0,0,0"/>

                <!-- Status Indicator -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                    <Ellipse Width="16" Height="16" Fill="{StaticResource StatusSuccessBrush}">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#00FF00" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="SYSTEM: OPERATIONAL" 
                              Foreground="{StaticResource StatusSuccessBrush}"
                              FontSize="12"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Service Browser -->
            <Border Grid.Column="0" 
                    Background="{StaticResource BackgroundSecondaryBrush}"
                    BorderBrush="{StaticResource Divider}"
                    BorderThickness="0,0,1,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="SERVICE TIERS" 
                                  Style="{StaticResource TextBlockHeadingStyle}"
                                  Margin="0,0,0,16"/>

                        <!-- Tier 1 -->
                        <Expander Header="⚡ TIER 1 - CORE" 
                                 Foreground="{StaticResource MonadoCyanBrush}"
                                 Background="Transparent"
                                 BorderThickness="0,0,0,1"
                                 BorderBrush="{StaticResource Divider}"
                                 Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <Button Content="System Monitor" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Background="Transparent"
                                       HorizontalAlignment="Left"
                                       Margin="0,4"/>
                                <Button Content="Process Manager" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Background="Transparent"
                                       HorizontalAlignment="Left"
                                       Margin="0,4"/>
                            </StackPanel>
                        </Expander>

                        <!-- Tier 2 -->
                        <Expander Header="🔵 TIER 2 - NETWORK" 
                                 Foreground="{StaticResource ElectricBlueBrush}"
                                 Background="Transparent"
                                 BorderThickness="0,0,0,1"
                                 BorderBrush="{StaticResource Divider}"
                                 Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <Button Content="Network Monitor" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Background="Transparent"
                                       HorizontalAlignment="Left"
                                       Margin="0,4"/>
                                <Button Content="Connection Manager" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Background="Transparent"
                                       HorizontalAlignment="Left"
                                       Margin="0,4"/>
                            </StackPanel>
                        </Expander>

                        <!-- Tier 3 -->
                        <Expander Header="💾 TIER 3 - STORAGE" 
                                 Foreground="{StaticResource GoldAccentBrush}"
                                 Background="Transparent"
                                 BorderThickness="0,0,0,1"
                                 BorderBrush="{StaticResource Divider}"
                                 Margin="0,0,0,8">
                            <StackPanel Margin="8">
                                <Button Content="Disk Monitor" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Background="Transparent"
                                       HorizontalAlignment="Left"
                                       Margin="0,4"/>
                                <Button Content="I/O Manager" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Background="Transparent"
                                       HorizontalAlignment="Left"
                                       Margin="0,4"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- CENTER PANEL: Main Dashboard -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24">
                    <!-- System Health Card -->
                    <Border Background="{StaticResource BackgroundTertiaryBrush}"
                            BorderBrush="{StaticResource MonadoCyanBrush}"
                            BorderThickness="2"
                            CornerRadius="8"
                            Margin="0,0,0,16"
                            Padding="16">
                        <Border.Effect>
                            <DropShadowEffect Color="#00D4FF" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- CPU -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CPU USAGE" 
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          FontSize="12"
                                          Margin="0,0,0,8"/>
                                <TextBlock Text="35.2%" 
                                          Foreground="{StaticResource MonadoCyanBrush}"
                                          FontSize="28"
                                          FontWeight="Bold"/>
                                <ProgressBar Background="{StaticResource BackgroundSecondaryBrush}"
                                           Foreground="{StaticResource MonadoCyanBrush}"
                                           Value="35.2"
                                           Height="6"
                                           Margin="0,8,0,0"
                                           CornerRadius="3"/>
                            </StackPanel>

                            <!-- RAM -->
                            <StackPanel Grid.Column="1" Margin="16,0">
                                <TextBlock Text="MEMORY USAGE" 
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          FontSize="12"
                                          Margin="0,0,0,8"/>
                                <TextBlock Text="52.8%" 
                                          Foreground="{StaticResource ElectricBlueBrush}"
                                          FontSize="28"
                                          FontWeight="Bold"/>
                                <ProgressBar Background="{StaticResource BackgroundSecondaryBrush}"
                                           Foreground="{StaticResource ElectricBlueBrush}"
                                           Value="52.8"
                                           Height="6"
                                           Margin="0,8,0,0"
                                           CornerRadius="3"/>
                            </StackPanel>

                            <!-- DISK -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="DISK USAGE" 
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          FontSize="12"
                                          Margin="0,0,0,8"/>
                                <TextBlock Text="67.4%" 
                                          Foreground="{StaticResource GoldAccentBrush}"
                                          FontSize="28"
                                          FontWeight="Bold"/>
                                <ProgressBar Background="{StaticResource BackgroundSecondaryBrush}"
                                           Foreground="{StaticResource GoldAccentBrush}"
                                           Value="67.4"
                                           Height="6"
                                           Margin="0,8,0,0"
                                           CornerRadius="3"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Service Cards Grid -->
                    <TextBlock Text="ACTIVE SERVICES" 
                              Style="{StaticResource TextBlockHeadingStyle}"
                              Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Service Card 1 -->
                        <Border Grid.Column="0"
                               Background="{StaticResource BackgroundSecondaryBrush}"
                               BorderBrush="{StaticResource MonadoCyanBrush}"
                               BorderThickness="2"
                               CornerRadius="6"
                               Margin="0,0,12,0"
                               Padding="12">
                            <Border.Effect>
                                <DropShadowEffect Color="#00D4FF" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>

                            <StackPanel>
                                <TextBlock Text="Monado Core Service" 
                                          Foreground="{StaticResource MonadoCyanBrush}"
                                          FontSize="14"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,8"/>
                                <TextBlock Text="Status: ⚡ ACTIVE" 
                                          Foreground="{StaticResource StatusSuccessBrush}"
                                          FontSize="12"
                                          Margin="0,0,0,4"/>
                                <TextBlock Text="Uptime: 14d 7h 32m" 
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <!-- Service Card 2 -->
                        <Border Grid.Column="1"
                               Background="{StaticResource BackgroundSecondaryBrush}"
                               BorderBrush="{StaticResource ElectricBlueBrush}"
                               BorderThickness="2"
                               CornerRadius="6"
                               Padding="12">
                            <Border.Effect>
                                <DropShadowEffect Color="#0080FF" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>

                            <StackPanel>
                                <TextBlock Text="Network Protocol Handler" 
                                          Foreground="{StaticResource ElectricBlueBrush}"
                                          FontSize="14"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,8"/>
                                <TextBlock Text="Status: ⚡ ACTIVE" 
                                          Foreground="{StaticResource StatusSuccessBrush}"
                                          FontSize="12"
                                          Margin="0,0,0,4"/>
                                <TextBlock Text="Packets: 42.8M/sec" 
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT PANEL: Alerts & Info -->
            <Border Grid.Column="2" 
                    Background="{StaticResource BackgroundSecondaryBrush}"
                    BorderBrush="{StaticResource Divider}"
                    BorderThickness="1,0,0,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="SYSTEM ALERTS" 
                                  Style="{StaticResource TextBlockHeadingStyle}"
                                  Margin="0,0,0,12"/>

                        <!-- Alert Item 1 -->
                        <Border Background="{StaticResource BackgroundTertiaryBrush}"
                               BorderBrush="{StaticResource StatusInfoBrush}"
                               BorderThickness="2,0,0,0"
                               Padding="8"
                               Margin="0,0,0,8"
                               CornerRadius="0,4,4,0">
                            <StackPanel>
                                <TextBlock Text="ℹ System Initialized" 
                                          Foreground="{StaticResource StatusInfoBrush}"
                                          FontSize="11"
                                          FontWeight="SemiBold"/>
                                <TextBlock Text="14:32:21" 
                                          Foreground="{StaticResource TextTertiaryBrush}"
                                          FontSize="10"
                                          Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Alert Item 2 -->
                        <Border Background="{StaticResource BackgroundTertiaryBrush}"
                               BorderBrush="{StaticResource StatusWarningBrush}"
                               BorderThickness="2,0,0,0"
                               Padding="8"
                               Margin="0,0,0,8"
                               CornerRadius="0,4,4,0">
                            <StackPanel>
                                <TextBlock Text="⚠ Memory Usage High" 
                                          Foreground="{StaticResource StatusWarningBrush}"
                                          FontSize="11"
                                          FontWeight="SemiBold"/>
                                <TextBlock Text="14:29:15" 
                                          Foreground="{StaticResource TextTertiaryBrush}"
                                          FontSize="10"
                                          Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Alert Item 3 -->
                        <Border Background="{StaticResource BackgroundTertiaryBrush}"
                               BorderBrush="{StaticResource StatusSuccessBrush}"
                               BorderThickness="2,0,0,0"
                               Padding="8"
                               Margin="0,0,0,8"
                               CornerRadius="0,4,4,0">
                            <StackPanel>
                                <TextBlock Text="✓ Service Online" 
                                          Foreground="{StaticResource StatusSuccessBrush}"
                                          FontSize="11"
                                          FontWeight="SemiBold"/>
                                <TextBlock Text="14:15:43" 
                                          Foreground="{StaticResource TextTertiaryBrush}"
                                          FontSize="10"
                                          Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Separator Background="{StaticResource Divider}" Margin="0,12"/>

                        <!-- System Info -->
                        <TextBlock Text="SYSTEM INFO" 
                                  Style="{StaticResource TextBlockHeadingStyle}"
                                  Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Uptime:" Foreground="{StaticResource TextTertiaryBrush}" FontSize="11" Margin="0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="14d 07:32" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,4" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Services:" Foreground="{StaticResource TextTertiaryBrush}" FontSize="11" Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="47/50 Online" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,4" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Temperature:" Foreground="{StaticResource TextTertiaryBrush}" FontSize="11" Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="38°C" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,4" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Network:" Foreground="{StaticResource TextTertiaryBrush}" FontSize="11" Margin="0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Connected ✓" Foreground="{StaticResource StatusSuccessBrush}" FontSize="11" Margin="0,4" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2" 
                Background="{StaticResource BackgroundSecondaryBrush}"
                BorderBrush="{StaticResource MonadoCyanBrush}"
                BorderThickness="0,2,0,0">

            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                          Text="HELIOS v1.0.0 | Xenoblade System Monitor | All Systems Nominal"
                          Foreground="{StaticResource TextTertiaryBrush}"
                          FontSize="11"
                          VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                          Text="FPS: 60 | Latency: 2ms | Threads: 12"
                          Foreground="{StaticResource MonadoCyanBrush}"
                          FontSize="11"
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
