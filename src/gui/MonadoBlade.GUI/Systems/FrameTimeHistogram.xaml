<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="MonadoBlade.GUI.Systems.FrameTimeHistogram"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="White"
             FontFamily="Consolas"
             FontSize="11">
    <Grid Margin="10">
        <StackPanel Orientation="Vertical" Spacing="5">
            <!-- Header -->
            <Border Background="#2C3E50" CornerRadius="5" Padding="10">
                <TextBlock Text="FRAME TIME HISTOGRAM" FontSize="12" FontWeight="Bold" Foreground="#ECF0F1"/>
            </Border>

            <!-- Percentile Stats -->
            <Border Background="#2C3E50" CornerRadius="5" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="P50" Foreground="#95A5A6" FontSize="9"/>
                        <TextBlock x:Name="P50Text" Text="0.0" Foreground="#3498DB" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text="ms" Foreground="#95A5A6" FontSize="8"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="P95" Foreground="#95A5A6" FontSize="9"/>
                        <TextBlock x:Name="P95Text" Text="0.0" Foreground="#F39C12" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text="ms" Foreground="#95A5A6" FontSize="8"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="P99" Foreground="#95A5A6" FontSize="9"/>
                        <TextBlock x:Name="P99Text" Text="0.0" Foreground="#E74C3C" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text="ms" Foreground="#95A5A6" FontSize="8"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="MAX" Foreground="#95A5A6" FontSize="9"/>
                        <TextBlock x:Name="MaxText" Text="0.0" Foreground="#C0392B" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text="ms" Foreground="#95A5A6" FontSize="8"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Histogram Visualization -->
            <Border Background="#2C3E50" CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="DISTRIBUTION (0-50ms bins)" Foreground="#95A5A6" FontSize="9" Margin="0,0,0,5"/>
                    <Canvas x:Name="HistogramCanvas" Background="#1A252F" Height="80"/>
                </StackPanel>
            </Border>

            <!-- Frame Time Stats -->
            <Border Background="#2C3E50" CornerRadius="5" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="AVERAGE" Foreground="#95A5A6" FontSize="9"/>
                        <TextBlock x:Name="AvgFrameTimeText" Text="0.0 ms" Foreground="#2ECC71" FontSize="12"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="OUTLIERS" Foreground="#95A5A6" FontSize="9"/>
                        <TextBlock x:Name="OutliersText" Text="0" Foreground="#E74C3C" FontSize="12"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="LOCKED" Foreground="#95A5A6" FontSize="9"/>
                        <TextBlock x:Name="LockedText" Text="No" Foreground="#3498DB" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
