<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================
         MONADO COLOR PALETTE - XENOBLADE INSPIRED
         Professional design with accessibility
         ============================================ -->

    <!-- PRIMARY MONADO COLORS -->
    <Color x:Key="ColorMonadoBlue">#00D9FF</Color>           <!-- Primary Monado Blue -->
    <Color x:Key="ColorMonadoCyan">#00F7FF</Color>           <!-- Bright Cyan -->
    <Color x:Key="ColorMonadoNavy">#00456B</Color>           <!-- Dark Navy -->
    <Color x:Key="ColorMonadoLight">#B0F5FF</Color>          <!-- Light Blue -->

    <!-- SECONDARY COLORS -->
    <Color x:Key="ColorElectricGreen">#00FF41</Color>        <!-- Success/Active -->
    <Color x:Key="ColorAmberGold">#FFB800</Color>            <!-- Warnings/Accents -->
    <Color x:Key="ColorMagentaRed">#FF0055</Color>           <!-- Errors/Critical -->
    <Color x:Key="ColorPureWhite">#FFFFFF</Color>            <!-- Text/Borders -->

    <!-- DARK MODE PALETTE -->
    <Color x:Key="ColorBackgroundDark">#0A1428</Color>       <!-- Very dark navy -->
    <Color x:Key="ColorBackgroundDarkAlt">#0F1D2E</Color>    <!-- Slightly lighter -->
    <Color x:Key="ColorSurfaceDark">#1A2838</Color>          <!-- Card background -->
    <Color x:Key="ColorSurfaceDarkAlt">#253548</Color>       <!-- Elevated surface -->
    <Color x:Key="ColorBorderDark">#3A5A78</Color>           <!-- Border color -->
    <Color x:Key="ColorBorderDarkFaint">#1E3A4F</Color>      <!-- Subtle borders -->

    <!-- LIGHT MODE PALETTE -->
    <Color x:Key="ColorBackgroundLight">#F5F7FA</Color>      <!-- Off-white -->
    <Color x:Key="ColorBackgroundLightAlt">#FFFBFE</Color>   <!-- Pure white variant -->
    <Color x:Key="ColorSurfaceLight">#FFFFFF</Color>         <!-- Pure white -->
    <Color x:Key="ColorBorderLight">#D0D8E0</Color>          <!-- Light gray -->
    <Color x:Key="ColorBorderLightFaint">#E8ECEF</Color>     <!-- Subtle light border -->

    <!-- TEXT COLORS -->
    <Color x:Key="ColorTextPrimaryDark">#E8E8E8</Color>      <!-- Main text on dark -->
    <Color x:Key="ColorTextSecondaryDark">#A8B0B8</Color>    <!-- Secondary on dark -->
    <Color x:Key="ColorTextDisabledDark">#606870</Color>     <!-- Disabled on dark -->
    <Color x:Key="ColorTextInverseDark">#1A2838</Color>      <!-- Text on light surfaces -->
    
    <Color x:Key="ColorTextPrimaryLight">#1A2838</Color>     <!-- Main text on light -->
    <Color x:Key="ColorTextSecondaryLight">#5A6B78</Color>   <!-- Secondary on light -->
    <Color x:Key="ColorTextDisabledLight">#A0A8B0</Color>    <!-- Disabled on light -->
    <Color x:Key="ColorTextInverseLight">#FFFFFF</Color>     <!-- Text on dark surfaces -->

    <!-- STATUS COLORS -->
    <Color x:Key="ColorSuccess">#00FF41</Color>              <!-- Green success -->
    <Color x:Key="ColorSuccessDark">#00AA2C</Color>          <!-- Dark green -->
    <Color x:Key="ColorWarning">#FFB800</Color>              <!-- Amber warning -->
    <Color x:Key="ColorWarningDark">#CC9500</Color>          <!-- Dark amber -->
    <Color x:Key="ColorError">#FF0055</Color>                <!-- Magenta error -->
    <Color x:Key="ColorErrorDark">#CC0044</Color>            <!-- Dark magenta -->
    <Color x:Key="ColorInfo">#00D9FF</Color>                 <!-- Cyan info -->
    <Color x:Key="ColorInfoDark">#00A8CC</Color>             <!-- Dark cyan -->

    <!-- ACCENT COLORS -->
    <Color x:Key="ColorAccentPrimary">#FFB800</Color>        <!-- Gold accent -->
    <Color x:Key="ColorAccentSecondary">#FF7700</Color>      <!-- Orange accent -->
    <Color x:Key="ColorAccentTertiary">#FFFFFF</Color>       <!-- Silver accent -->

    <!-- GRADIENT COLORS FOR PREMIUM EFFECTS -->
    <Color x:Key="ColorGradientStart">#00D9FF</Color>        <!-- Cyan start -->
    <Color x:Key="ColorGradientEnd">#0056A8</Color>          <!-- Navy end -->

    <!-- DARK MODE BRUSHES -->
    <SolidColorBrush x:Key="BrushMonadoBlue" Color="{StaticResource ColorMonadoBlue}"/>
    <SolidColorBrush x:Key="BrushMonadoCyan" Color="{StaticResource ColorMonadoCyan}"/>
    <SolidColorBrush x:Key="BrushMonadoNavy" Color="{StaticResource ColorMonadoNavy}"/>
    
    <SolidColorBrush x:Key="BrushBackgroundDark" Color="{StaticResource ColorBackgroundDark}"/>
    <SolidColorBrush x:Key="BrushSurfaceDark" Color="{StaticResource ColorSurfaceDark}"/>
    <SolidColorBrush x:Key="BrushBorderDark" Color="{StaticResource ColorBorderDark}"/>
    
    <SolidColorBrush x:Key="BrushTextPrimaryDark" Color="{StaticResource ColorTextPrimaryDark}"/>
    <SolidColorBrush x:Key="BrushTextSecondaryDark" Color="{StaticResource ColorTextSecondaryDark}"/>

    <!-- LIGHT MODE BRUSHES -->
    <SolidColorBrush x:Key="BrushBackgroundLight" Color="{StaticResource ColorBackgroundLight}"/>
    <SolidColorBrush x:Key="BrushSurfaceLight" Color="{StaticResource ColorSurfaceLight}"/>
    <SolidColorBrush x:Key="BrushBorderLight" Color="{StaticResource ColorBorderLight}"/>
    
    <SolidColorBrush x:Key="BrushTextPrimaryLight" Color="{StaticResource ColorTextPrimaryLight}"/>
    <SolidColorBrush x:Key="BrushTextSecondaryLight" Color="{StaticResource ColorTextSecondaryLight}"/>

    <!-- STATUS BRUSHES -->
    <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource ColorSuccess}"/>
    <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource ColorWarning}"/>
    <SolidColorBrush x:Key="BrushError" Color="{StaticResource ColorError}"/>
    <SolidColorBrush x:Key="BrushInfo" Color="{StaticResource ColorInfo}"/>

    <!-- GRADIENT BRUSHES -->
    <LinearGradientBrush x:Key="BrushGradientMonado" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource ColorMonadoBlue}" Offset="0"/>
        <GradientStop Color="{StaticResource ColorMonadoCyan}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BrushGradientPremium" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource ColorGradientStart}" Offset="0"/>
        <GradientStop Color="{StaticResource ColorGradientEnd}" Offset="1"/>
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="BrushRadialMonado" Center="0.5,0.5">
        <GradientStop Color="{StaticResource ColorMonadoLight}" Offset="0"/>
        <GradientStop Color="{StaticResource ColorMonadoNavy}" Offset="1"/>
    </RadialGradientBrush>

    <!-- SEMI-TRANSPARENT OVERLAYS (Accessibility) -->
    <SolidColorBrush x:Key="BrushMonadoBlueOverlay" Color="{StaticResource ColorMonadoBlue}" Opacity="0.1"/>
    <SolidColorBrush x:Key="BrushMonadoBlueOverlayMedium" Color="{StaticResource ColorMonadoBlue}" Opacity="0.25"/>
    <SolidColorBrush x:Key="BrushMonadoBlueOverlayStrong" Color="{StaticResource ColorMonadoBlue}" Opacity="0.5"/>

    <!-- DARK MODE SHADOW COLORS -->
    <Color x:Key="ColorShadow">#000000</Color>
    <SolidColorBrush x:Key="BrushShadowLight" Color="{StaticResource ColorShadow}" Opacity="0.2"/>
    <SolidColorBrush x:Key="BrushShadowMedium" Color="{StaticResource ColorShadow}" Opacity="0.4"/>
    <SolidColorBrush x:Key="BrushShadowStrong" Color="{StaticResource ColorShadow}" Opacity="0.6"/>

    <!-- HIGHLIGHT/GLOW COLORS -->
    <Color x:Key="ColorGlow">#00FF41</Color>
    <SolidColorBrush x:Key="BrushGlowSubtle" Color="{StaticResource ColorGlow}" Opacity="0.15"/>
    <SolidColorBrush x:Key="BrushGlowMedium" Color="{StaticResource ColorGlow}" Opacity="0.3"/>
    <SolidColorBrush x:Key="BrushGlowStrong" Color="{StaticResource ColorGlow}" Opacity="0.6"/>

    <!-- HIGH CONTRAST VARIANTS (Accessibility) -->
    <Color x:Key="ColorHighContrastBackground">#000000</Color>
    <Color x:Key="ColorHighContrastText">#FFFFFF</Color>
    <Color x:Key="ColorHighContrastAccent">#FFFF00</Color>

    <SolidColorBrush x:Key="BrushHighContrastBackground" Color="{StaticResource ColorHighContrastBackground}"/>
    <SolidColorBrush x:Key="BrushHighContrastText" Color="{StaticResource ColorHighContrastText}"/>
    <SolidColorBrush x:Key="BrushHighContrastAccent" Color="{StaticResource ColorHighContrastAccent}"/>

</ResourceDictionary>
