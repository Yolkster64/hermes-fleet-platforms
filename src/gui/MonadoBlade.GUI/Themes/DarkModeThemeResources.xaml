<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DARK MODE THEME RESOURCES -->
    <!-- WCAG AAA Compliant Color Palette -->

    <!-- Base Background Colors -->
    <Color x:Key="DarkBackgroundColor">#0F0F14</Color>
    <Color x:Key="DarkSurfaceColor">#191923</Color>
    <Color x:Key="DarkSurfaceVariantColor">#232332</Color>

    <!-- Text Colors (WCAG AAA Compliant) -->
    <Color x:Key="TextPrimaryColor">#F0F1F5</Color>
    <Color x:Key="TextSecondaryColor">#B4B9C8</Color>
    <Color x:Key="TextTertiaryColor">#828CA0</Color>
    <Color x:Key="TextDisabledColor">#646978</Color>

    <!-- Accent Colors -->
    <Color x:Key="AccentPrimaryColor">#50C8FF</Color>
    <Color x:Key="AccentSecondaryColor">#78DCFF</Color>
    <Color x:Key="AccentTertiaryColor">#3CB4FF</Color>

    <!-- Semantic Colors -->
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FFC107</Color>
    <Color x:Key="ErrorColor">#EF5350</Color>
    <Color x:Key="InfoColor">#2196F3</Color>

    <!-- Button Colors -->
    <Color x:Key="ButtonPrimaryBackground">#50C8FF</Color>
    <Color x:Key="ButtonPrimaryText">#0F0F14</Color>
    <Color x:Key="ButtonPrimaryHover">#78DCFF</Color>
    <Color x:Key="ButtonSecondaryBackground">#2D2D3C</Color>
    <Color x:Key="ButtonSecondaryText">#F0F1F5</Color>
    <Color x:Key="ButtonSecondaryHover">#414155</Color>
    <Color x:Key="ButtonSecondaryBorder">#464A5A</Color>

    <!-- Input Colors -->
    <Color x:Key="InputBackgroundColor">#1E1E28</Color>
    <Color x:Key="InputBorderColor">#3C3C50</Color>
    <Color x:Key="InputFocusColor">#50C8FF</Color>
    <Color x:Key="InputTextColor">#F0F1F5</Color>
    <Color x:Key="InputPlaceholderColor">#828CA0</Color>

    <!-- Border and Divider Colors -->
    <Color x:Key="BorderPrimaryColor">#323246</Color>
    <Color x:Key="BorderSecondaryColor">#282837</Color>
    <Color x:Key="DividerColor">#2D2D3C</Color>

    <!-- Interactive Element Colors -->
    <Color x:Key="SelectionBackgroundColor">#50C8FF</Color>
    <Color x:Key="HoverBackgroundColor">#3C3C50</Color>
    <Color x:Key="FocusRingColor">#78DCFF</Color>

    <!-- Overlay Colors -->
    <Color x:Key="OverlayBackgroundColor">#000000</Color>
    <Color x:Key="ToastBackgroundColor">#232332</Color>

    <!-- Brushes for Easier Binding -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource DarkBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource DarkSurfaceColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{DynamicResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentPrimaryColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{DynamicResource ErrorColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderPrimaryColor}" />

    <!-- Typography Settings -->
    <sys:Double x:Key="FontSizeLarge">18</sys:Double>
    <sys:Double x:Key="FontSizeRegular">14</sys:Double>
    <sys:Double x:Key="FontSizeSmall">12</sys:Double>
    <sys:Double x:Key="FontSizeXSmall">10</sys:Double>
    <sys:Double x:Key="HeadingSize">28</sys:Double>
    <sys:Double x:Key="SubheadingSize">20</sys:Double>
    <sys:Double x:Key="BodySize">14</sys:Double>
    <sys:Double x:Key="CaptionSize">12</sys:Double>

    <FontFamily x:Key="FontFamilyPrimary">Segoe UI</FontFamily>
    <FontFamily x:Key="FontFamilyMonospace">Consolas</FontFamily>
    <FontFamily x:Key="FontFamilyHeading">Segoe UI</FontFamily>

    <!-- Spacing System -->
    <sys:Double x:Key="Spacing2">2</sys:Double>
    <sys:Double x:Key="Spacing4">4</sys:Double>
    <sys:Double x:Key="Spacing8">8</sys:Double>
    <sys:Double x:Key="Spacing12">12</sys:Double>
    <sys:Double x:Key="Spacing16">16</sys:Double>
    <sys:Double x:Key="Spacing20">20</sys:Double>
    <sys:Double x:Key="Spacing24">24</sys:Double>
    <sys:Double x:Key="Spacing32">32</sys:Double>

    <!-- Corner Radius -->
    <CornerRadius x:Key="CornerRadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="CornerRadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusLarge">12</CornerRadius>
    <CornerRadius x:Key="CornerRadiusXLarge">16</CornerRadius>

    <!-- Thickness for Margins and Padding -->
    <Thickness x:Key="SmallMargin">8</Thickness>
    <Thickness x:Key="StandardMargin">16</Thickness>
    <Thickness x:Key="LargeMargin">24</Thickness>

    <!-- Animation Durations (in milliseconds) -->
    <Duration x:Key="FastAnimationDuration">0:0:0.150</Duration>
    <Duration x:Key="StandardAnimationDuration">0:0:0.250</Duration>
    <Duration x:Key="SlowAnimationDuration">0:0:0.400</Duration>

    <!-- Shadow Effects -->
    <DropShadowEffect x:Key="ShadowSmall" BlurRadius="4" Opacity="0.3" ShadowDepth="2" />
    <DropShadowEffect x:Key="ShadowMedium" BlurRadius="8" Opacity="0.4" ShadowDepth="4" />
    <DropShadowEffect x:Key="ShadowLarge" BlurRadius="12" Opacity="0.5" ShadowDepth="6" />

</ResourceDictionary>
