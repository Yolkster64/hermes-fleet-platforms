<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================
         XENOBLADE MONADO BLADE MASTER THEME SYSTEM
         Complete OS UI theming for professional quality
         ============================================ -->

    <!-- PRIMARY COLORS -->
    <Color x:Key="ColorPrimary">#00D9FF</Color>          <!-- Cyan - Main UI color -->
    <Color x:Key="ColorSecondary">#00FF41</Color>        <!-- Electric Green - Success/Active -->
    <Color x:Key="ColorAccent">#FFB800</Color>           <!-- Amber - Highlights/Warnings -->
    <Color x:Key="ColorDanger">#FF0055</Color>           <!-- Magenta - Errors/Critical -->
    <Color x:Key="ColorNeutral">#FFFFFF</Color>          <!-- White - Text/Borders -->

    <!-- DARK MODE PALETTE -->
    <Color x:Key="ColorBackground">#0A1428</Color>       <!-- Very dark navy -->
    <Color x:Key="ColorBackgroundAlt">#0F1D2E</Color>    <!-- Slightly lighter navy -->
    <Color x:Key="ColorSurface">#1A2838</Color>          <!-- Card/Panel background -->
    <Color x:Key="ColorSurfaceAlt">#253548</Color>       <!-- Elevated surface -->
    <Color x:Key="ColorBorder">#3A5A78</Color>           <!-- Border color -->

    <!-- LIGHT MODE PALETTE -->
    <Color x:Key="ColorBackgroundLight">#F5F7FA</Color>  <!-- Off-white -->
    <Color x:Key="ColorSurfaceLight">#FFFFFF</Color>     <!-- Pure white -->
    <Color x:Key="ColorBorderLight">#D0D8E0</Color>      <!-- Light gray border -->

    <!-- TEXT COLORS -->
    <Color x:Key="ColorTextPrimary">#E8E8E8</Color>      <!-- Main text -->
    <Color x:Key="ColorTextSecondary">#A8B0B8</Color>    <!-- Secondary text -->
    <Color x:Key="ColorTextDisabled">#606870</Color>     <!-- Disabled text -->
    <Color x:Key="ColorTextInverse">#1A2838</Color>      <!-- Text on light backgrounds -->

    <!-- STATUS COLORS -->
    <Color x:Key="ColorSuccess">#00FF41</Color>          <!-- Green - Success -->
    <Color x:Key="ColorWarning">#FFB800</Color>          <!-- Amber - Warning -->
    <Color x:Key="ColorError">#FF0055</Color>            <!-- Magenta - Error -->
    <Color x:Key="ColorInfo">#00D9FF</Color>             <!-- Cyan - Info -->

    <!-- BRUSHES -->
    <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}"/>
    <SolidColorBrush x:Key="BrushSecondary" Color="{StaticResource ColorSecondary}"/>
    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="BrushDanger" Color="{StaticResource ColorDanger}"/>
    <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource ColorBackground}"/>
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorSurface}"/>
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}"/>

    <!-- GRADIENTS -->
    <LinearGradientBrush x:Key="GradientPrimaryButton" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0A8FA8" Offset="0"/>
        <GradientStop Color="#00D9FF" Offset="0.5"/>
        <GradientStop Color="#0080C0" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GradientBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0A1428" Offset="0"/>
        <GradientStop Color="#1A3A5A" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GradientAccent" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF0055" Offset="0"/>
        <GradientStop Color="#FFB800" Offset="1"/>
    </LinearGradientBrush>

    <!-- FONTS & TYPOGRAPHY -->
    <FontFamily x:Key="FontFamily">Segoe UI</FontFamily>
    <FontFamily x:Key="FontFamilyMono">Consolas</FontFamily>

    <!-- Font Sizes -->
    <sys:Double x:Key="FontSizeDisplay">32</sys:Double>
    <sys:Double x:Key="FontSizeHeading1">28</sys:Double>
    <sys:Double x:Key="FontSizeHeading2">24</sys:Double>
    <sys:Double x:Key="FontSizeHeading3">20</sys:Double>
    <sys:Double x:Key="FontSizeBody">14</sys:Double>
    <sys:Double x:Key="FontSizeBodySmall">12</sys:Double>
    <sys:Double x:Key="FontSizeCaption">11</sys:Double>

    <!-- SPACING & SIZING -->
    <Thickness x:Key="SpacingXXSmall">4</Thickness>
    <Thickness x:Key="SpacingXSmall">8</Thickness>
    <Thickness x:Key="SpacingSmall">12</Thickness>
    <Thickness x:Key="SpacingMedium">16</Thickness>
    <Thickness x:Key="SpacingLarge">24</Thickness>
    <Thickness x:Key="SpacingXLarge">32</Thickness>

    <sys:Double x:Key="CornerRadiusSmall">4</sys:Double>
    <sys:Double x:Key="CornerRadiusMedium">8</sys:Double>
    <sys:Double x:Key="CornerRadiusLarge">12</sys:Double>

    <!-- BUTTON STYLE -->
    <Style x:Key="ButtonPrimaryStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource GradientPrimaryButton}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimary}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamily}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border x:Name="border" 
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="border" Property="Background" Value="#00E8FF"/>
                        <Setter TargetName="border" Property="Effect">
                            <Setter.Value>
                                <DropShadow ShadowDepth="0" BlurRadius="10" Color="#00D9FF" Opacity="0.6"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="border" Property="Background" Value="#0080C0"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style x:Key="ButtonSecondaryStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimary}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamily}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border x:Name="border" 
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="border" Property="Background" Value="#1A3A5A"/>
                        <Setter TargetName="border" Property="BorderBrush" Value="#00E8FF"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="border" Property="Background" Value="#0A2A4A"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- TEXTBOX STYLE -->
    <Style x:Key="TextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BrushSurface}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamily}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CaretBrush" Value="{StaticResource BrushPrimary}"/>
        <Setter Property="Template">
            <ControlTemplate TargetType="TextBox">
                <Border x:Name="border" 
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4"
                        Padding="{TemplateBinding Padding}">
                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushPrimary}"/>
                    </Trigger>
                    <Trigger Property="IsFocused" Value="True">
                        <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushPrimary}"/>
                        <Setter TargetName="border" Property="Effect">
                            <Setter.Value>
                                <DropShadow ShadowDepth="0" BlurRadius="8" Color="#00D9FF" Opacity="0.4"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- SLIDER STYLE -->
    <Style x:Key="SliderStyle" TargetType="Slider">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushPrimary}"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Template">
            <ControlTemplate TargetType="Slider">
                <Grid x:Name="grid" Margin="0">
                    <Track x:Name="PART_Track">
                        <Track.DecreaseRepeatButton>
                            <RepeatButton Command="Slider.DecreaseLarge" Style="{StaticResource SliderButtonStyle}"/>
                        </Track.DecreaseRepeatButton>
                        <Track.Thumb>
                            <Thumb x:Name="Thumb" Style="{StaticResource SliderThumbStyle}"/>
                        </Track.Thumb>
                        <Track.IncreaseRepeatButton>
                            <RepeatButton Command="Slider.IncreaseLarge" Style="{StaticResource SliderButtonStyle}"/>
                        </Track.IncreaseRepeatButton>
                    </Track>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style x:Key="SliderThumbStyle" TargetType="Thumb">
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Background" Value="{StaticResource BrushPrimary}"/>
        <Setter Property="Template">
            <ControlTemplate TargetType="Thumb">
                <Ellipse Fill="{TemplateBinding Background}" 
                         Stroke="{StaticResource BrushBorder}" 
                         StrokeThickness="1"/>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style x:Key="SliderButtonStyle" TargetType="RepeatButton">
        <Setter Property="Template">
            <ControlTemplate TargetType="RepeatButton">
                <Border Background="Transparent">
                    <Rectangle Fill="{TemplateBinding Background}"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- SCROLLBAR STYLE -->
    <Style x:Key="ScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Width" Value="12"/>
        <Setter Property="Template">
            <ControlTemplate TargetType="ScrollBar">
                <Border Background="Transparent">
                    <Track IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                           x:Name="PART_Track">
                        <Track.Thumb>
                            <Thumb x:Name="Thumb">
                                <Thumb.Style>
                                    <Style TargetType="Thumb">
                                        <Setter Property="Background" Value="#3A5A78"/>
                                        <Setter Property="Template">
                                            <ControlTemplate TargetType="Thumb">
                                                <Rectangle Fill="{TemplateBinding Background}" 
                                                           RadiusX="4" RadiusY="4"
                                                           Margin="2"/>
                                            </ControlTemplate>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BrushPrimary}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Thumb.Style>
                            </Track.Thumb>
                        </Track.DecreaseRepeatButton>
                        <Track.IncreaseRepeatButton/>
                    </Track>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- PROGRESS BAR STYLE -->
    <Style x:Key="ProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="6"/>
        <Setter Property="Background" Value="#1A3A5A"/>
        <Setter Property="Foreground" Value="{StaticResource GradientPrimaryButton}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <ControlTemplate TargetType="ProgressBar">
                <Border Background="{TemplateBinding Background}" CornerRadius="3">
                    <Rectangle Fill="{TemplateBinding Foreground}" x:Name="PART_Indicator" CornerRadius="3"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- CHECKBOX STYLE -->
    <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamily}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Template">
            <ControlTemplate TargetType="CheckBox">
                <StackPanel Orientation="Horizontal">
                    <Border x:Name="checkBorder"
                            Width="20" Height="20"
                            Background="{StaticResource BrushSurface}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1.5"
                            CornerRadius="3">
                        <TextBlock Text="✓" 
                                   Foreground="{StaticResource BrushSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   Opacity="0"
                                   x:Name="checkmark"/>
                    </Border>
                    <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="checkmark" Property="Opacity" Value="1"/>
                        <Setter TargetName="checkBorder" Property="Background" Value="{StaticResource BrushPrimary}"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="checkBorder" Property="BorderBrush" Value="{StaticResource BrushPrimary}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- WINDOW CHROME STYLE -->
    <Style x:Key="WindowChromeStyle" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BrushBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamily}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- TOGGLE BUTTON STYLE -->
    <Style x:Key="ToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Background" Value="#3A5A78"/>
        <Setter Property="Template">
            <ControlTemplate TargetType="ToggleButton">
                <Border x:Name="border" 
                        Background="{TemplateBinding Background}"
                        CornerRadius="12"
                        Padding="2">
                    <Ellipse x:Name="toggle" 
                             Fill="{StaticResource BrushPrimary}"
                             HorizontalAlignment="Left"
                             Width="20" Height="20"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="border" Property="Background" Value="{StaticResource BrushSecondary}"/>
                        <Setter TargetName="toggle" Property="HorizontalAlignment" Value="Right"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- LISTBOX STYLE -->
    <Style x:Key="ListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource BrushSurface}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="Margin" Value="0,2"/>
                    <Setter Property="Template">
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    CornerRadius="4">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#1A3A5A"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource BrushPrimary}"/>
                                    <Setter Property="Foreground" Value="{StaticResource BrushTextInverse}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- GROUPBOX STYLE -->
    <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Template">
            <ControlTemplate TargetType="GroupBox">
                <Border x:Name="border"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6"
                        Background="{StaticResource BrushSurface}">
                    <StackPanel>
                        <TextBlock Text="{TemplateBinding Header}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Margin="0,0,0,8"
                                   Opacity="0.8"/>
                        <ContentPresenter Margin="{TemplateBinding Padding}"/>
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- CONTEXT MENU STYLE -->
    <Style x:Key="ContextMenuStyle" TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceAlt}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
    </Style>

    <!-- TOOLTIP STYLE -->
    <Style x:Key="ToolTipStyle" TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceAlt}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimary}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

</ResourceDictionary>
