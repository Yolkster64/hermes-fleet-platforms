<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="MonadoBlade.GUI.Views.ThemeSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{StaticResource BrushBackgroundDark}"
             Foreground="{StaticResource BrushTextPrimaryDark}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   Text="Theme Settings"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,16"
                   Foreground="{StaticResource BrushMonadoBlue}"/>

        <!-- Preset Themes Section -->
        <GroupBox Grid.Row="1" Header="Preset Themes" Margin="0,0,0,16">
            <GroupBox.Foreground>
                <SolidColorBrush Color="{StaticResource ColorTextPrimaryDark}"/>
            </GroupBox.Foreground>
            <StackPanel Margin="8">
                <ItemsControl ItemsSource="{Binding PresetThemes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.SelectThemeCommand}"
                                    CommandParameter="{Binding Id}"
                                    Margin="4"
                                    Padding="12,8"
                                    Background="{Binding PreviewColor, Converter={StaticResource ColorToBrushConverter}}"
                                    Foreground="{StaticResource BrushTextPrimaryDark}"
                                    FontSize="14"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </GroupBox>

        <!-- Custom Theme Section -->
        <GroupBox Grid.Row="2" Header="Customize Theme" Margin="0,0,0,16">
            <GroupBox.Foreground>
                <SolidColorBrush Color="{StaticResource ColorTextPrimaryDark}"/>
            </GroupBox.Foreground>
            <StackPanel Margin="8">
                <!-- Primary Color Picker -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Primary Color:" Margin="0,0,0,4"/>
                    <Grid Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0"
                                   Fill="{Binding CurrentTheme.PrimaryColor, Converter={StaticResource ColorToBrushConverter}}"
                                   Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding CurrentTheme.PrimaryColor}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondaryDark}"/>
                    </Grid>
                </StackPanel>

                <!-- Secondary Color Picker -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Secondary Color:" Margin="0,0,0,4"/>
                    <Grid Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0"
                                   Fill="{Binding CurrentTheme.SecondaryColor, Converter={StaticResource ColorToBrushConverter}}"
                                   Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding CurrentTheme.SecondaryColor}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondaryDark}"/>
                    </Grid>
                </StackPanel>

                <!-- Accent Color Picker -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Accent Color:" Margin="0,0,0,4"/>
                    <Grid Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0"
                                   Fill="{Binding CurrentTheme.AccentColor, Converter={StaticResource ColorToBrushConverter}}"
                                   Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding CurrentTheme.AccentColor}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondaryDark}"/>
                    </Grid>
                </StackPanel>

                <!-- Opacity/Brightness Slider -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Brightness:" Margin="0,0,0,4"/>
                    <Slider Value="{Binding CurrentTheme.Brightness, Mode=TwoWay}"
                            Minimum="0.3" Maximum="1.0" SmallChange="0.05" LargeChange="0.1"
                            Foreground="{StaticResource BrushMonadoBlue}"/>
                    <TextBlock Text="{Binding CurrentTheme.Brightness, StringFormat={}{0:P0}}"
                               Foreground="{StaticResource BrushTextSecondaryDark}"
                               FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Preview Section -->
        <GroupBox Grid.Row="3" Header="Preview" Margin="0,0,0,16" Height="150">
            <GroupBox.Foreground>
                <SolidColorBrush Color="{StaticResource ColorTextPrimaryDark}"/>
            </GroupBox.Foreground>
            <Border Background="{Binding CurrentTheme.BackgroundColor, Converter={StaticResource ColorToBrushConverter}}"
                    CornerRadius="4"
                    Margin="8">
                <StackPanel Margin="12" VerticalAlignment="Center">
                    <TextBlock Text="Preview Text - Primary" 
                               Foreground="{Binding CurrentTheme.PrimaryColor, Converter={StaticResource ColorToBrushConverter}}"
                               FontSize="14" Margin="0,0,0,8"/>
                    <TextBlock Text="Preview Text - Secondary" 
                               Foreground="{Binding CurrentTheme.SecondaryColor, Converter={StaticResource ColorToBrushConverter}}"
                               FontSize="14" Margin="0,0,0,8"/>
                    <TextBlock Text="Preview Text - Accent" 
                               Foreground="{Binding CurrentTheme.AccentColor, Converter={StaticResource ColorToBrushConverter}}"
                               FontSize="14"/>
                </StackPanel>
            </Border>
        </GroupBox>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Apply Theme"
                    Command="{Binding ApplyThemeCommand}"
                    Padding="16,8"
                    Margin="0,0,8,0"
                    Background="{StaticResource BrushMonadoBlue}"
                    Foreground="{StaticResource BrushTextInverseDark}"/>
            <Button Content="Save Theme"
                    Command="{Binding SaveThemeCommand}"
                    Padding="16,8"
                    Margin="0,0,8,0"
                    Background="{StaticResource BrushSuccess}"
                    Foreground="{StaticResource BrushTextInverseDark}"/>
            <Button Content="Reset to Default"
                    Command="{Binding ResetThemeCommand}"
                    Padding="16,8"
                    Background="{StaticResource BrushWarning}"
                    Foreground="{StaticResource BrushTextInverseDark}"/>
        </StackPanel>
    </Grid>
</UserControl>
