<UserControl
    x:Class="MonadoBlade.GUI.Views.Settings.SettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0D0D0D">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Navigation Panel -->
        <StackPanel Grid.Column="0" Background="#1A1A1A" Margin="0">
            <TextBlock
                Text="SETTINGS"
                Foreground="#00D4FF"
                FontSize="18"
                FontWeight="Bold"
                Margin="20,20,20,30"
                LetterSpacing="2" />

            <ListBox
                x:Name="SettingsCategoryListBox"
                Background="Transparent"
                BorderThickness="0"
                SelectionChanged="SettingsCategoryListBox_SelectionChanged">

                <ListBoxItem
                    Tag="Appearance"
                    Style="{StaticResource SettingsCategoryItem}">
                    <TextBlock Text="Appearance" Foreground="#E0E0E0" />
                </ListBoxItem>

                <ListBoxItem
                    Tag="Performance"
                    Style="{StaticResource SettingsCategoryItem}">
                    <TextBlock Text="Performance" Foreground="#E0E0E0" />
                </ListBoxItem>

                <ListBoxItem
                    Tag="System"
                    Style="{StaticResource SettingsCategoryItem}">
                    <TextBlock Text="System" Foreground="#E0E0E0" />
                </ListBoxItem>

                <ListBoxItem
                    Tag="Accessibility"
                    Style="{StaticResource SettingsCategoryItem}">
                    <TextBlock Text="Accessibility" Foreground="#E0E0E0" />
                </ListBoxItem>

                <ListBoxItem
                    Tag="About"
                    Style="{StaticResource SettingsCategoryItem}">
                    <TextBlock Text="About" Foreground="#E0E0E0" />
                </ListBoxItem>
            </ListBox>
        </StackPanel>

        <!-- Right Settings Panel -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,40,40,40">
                <!-- Appearance Settings -->
                <StackPanel x:Name="AppearancePanel" Visibility="Visible">
                    <TextBlock
                        Text="Appearance"
                        Foreground="#00D4FF"
                        FontSize="20"
                        FontWeight="Bold"
                        Margin="0,0,0,20" />

                    <!-- Theme Selection -->
                    <Border
                        Background="#1A1A1A"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock
                                Text="Theme"
                                Foreground="#E0E0E0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Margin="0,0,0,10" />

                            <ComboBox
                                x:Name="ThemeComboBox"
                                Background="#2A2A2A"
                                Foreground="#E0E0E0"
                                BorderBrush="#00D4FF"
                                BorderThickness="1"
                                Padding="10,8"
                                SelectionChanged="ThemeComboBox_SelectionChanged">
                                <ComboBoxItem>Monado Dark (Default)</ComboBoxItem>
                                <ComboBoxItem>Monado Light</ComboBoxItem>
                                <ComboBoxItem>High Contrast</ComboBoxItem>
                                <ComboBoxItem>Classic</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Accent Color -->
                    <Border
                        Background="#1A1A1A"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock
                                Text="Accent Color"
                                Foreground="#E0E0E0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Margin="0,0,0,10" />

                            <StackPanel Orientation="Horizontal" Height="40">
                                <Button
                                    Content="Cyan"
                                    Background="#00D4FF"
                                    Foreground="#000"
                                    Margin="0,0,10,0"
                                    Click="AccentColor_Click"
                                    Padding="15,0" />
                                <Button
                                    Content="Purple"
                                    Background="#7F4FFF"
                                    Foreground="#FFF"
                                    Margin="0,0,10,0"
                                    Click="AccentColor_Click"
                                    Padding="15,0" />
                                <Button
                                    Content="Pink"
                                    Background="#FF1493"
                                    Foreground="#FFF"
                                    Margin="0,0,10,0"
                                    Click="AccentColor_Click"
                                    Padding="15,0" />
                                <Button
                                    Content="Green"
                                    Background="#00FF96"
                                    Foreground="#000"
                                    Click="AccentColor_Click"
                                    Padding="15,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Transparency -->
                    <Border
                        Background="#1A1A1A"
                        CornerRadius="8"
                        Padding="20">
                        <StackPanel>
                            <TextBlock
                                Text="Window Transparency"
                                Foreground="#E0E0E0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Margin="0,0,0,10" />

                            <Slider
                                x:Name="TransparencySlider"
                                Minimum="0"
                                Maximum="100"
                                Value="85"
                                Foreground="#00D4FF"
                                Margin="0,0,0,10"
                                ValueChanged="TransparencySlider_ValueChanged" />

                            <TextBlock
                                x:Name="TransparencyValueText"
                                Text="85%"
                                Foreground="#00D4FF"
                                FontSize="12" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Performance Settings -->
                <StackPanel x:Name="PerformancePanel" Visibility="Collapsed">
                    <TextBlock
                        Text="Performance"
                        Foreground="#00D4FF"
                        FontSize="20"
                        FontWeight="Bold"
                        Margin="0,0,0,20" />

                    <Border Background="#1A1A1A" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock
                                Text="GPU Acceleration"
                                Foreground="#E0E0E0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Margin="0,0,0,10" />

                            <CheckBox
                                x:Name="GpuAccelCheckBox"
                                Content="Enable Hardware Acceleration"
                                Foreground="#E0E0E0"
                                IsChecked="True"
                                Checked="GpuAccelCheckBox_Checked" />
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A1A" CornerRadius="8" Padding="20">
                        <StackPanel>
                            <TextBlock
                                Text="Animation Quality"
                                Foreground="#E0E0E0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Margin="0,0,0,10" />

                            <ComboBox
                                x:Name="AnimationQualityComboBox"
                                Background="#2A2A2A"
                                Foreground="#E0E0E0"
                                BorderBrush="#00D4FF"
                                Padding="10,8">
                                <ComboBoxItem>Low (Better Performance)</ComboBoxItem>
                                <ComboBoxItem>Medium (Balanced)</ComboBoxItem>
                                <ComboBoxItem IsSelected="True">High (Best Quality)</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- System Settings -->
                <StackPanel x:Name="SystemPanel" Visibility="Collapsed">
                    <TextBlock
                        Text="System"
                        Foreground="#00D4FF"
                        FontSize="20"
                        FontWeight="Bold"
                        Margin="0,0,0,20" />

                    <Border Background="#1A1A1A" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock
                                Text="Startup Behavior"
                                Foreground="#E0E0E0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Margin="0,0,0,10" />

                            <CheckBox
                                x:Name="StartupCheckBox"
                                Content="Launch at System Startup"
                                Foreground="#E0E0E0"
                                Checked="StartupCheckBox_Checked" />

                            <CheckBox
                                x:Name="MinimizedCheckBox"
                                Content="Start Minimized"
                                Foreground="#E0E0E0"
                                Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A1A" CornerRadius="8" Padding="20">
                        <StackPanel>
                            <TextBlock
                                Text="Global Hotkeys"
                                Foreground="#E0E0E0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Margin="0,0,0,10" />

                            <CheckBox
                                x:Name="GlobalHotkeysCheckBox"
                                Content="Enable Global Keyboard Shortcuts"
                                Foreground="#E0E0E0"
                                IsChecked="True" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Accessibility Settings -->
                <StackPanel x:Name="AccessibilityPanel" Visibility="Collapsed">
                    <TextBlock
                        Text="Accessibility"
                        Foreground="#00D4FF"
                        FontSize="20"
                        FontWeight="Bold"
                        Margin="0,0,0,20" />

                    <Border Background="#1A1A1A" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock
                                Text="Text Scaling"
                                Foreground="#E0E0E0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Margin="0,0,0,10" />

                            <Slider
                                x:Name="TextScaleSlider"
                                Minimum="0.8"
                                Maximum="2.0"
                                Value="1.0"
                                Foreground="#00D4FF"
                                ValueChanged="TextScaleSlider_ValueChanged" />
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A1A" CornerRadius="8" Padding="20">
                        <StackPanel>
                            <CheckBox
                                x:Name="HighContrastCheckBox"
                                Content="High Contrast Mode"
                                Foreground="#E0E0E0"
                                Checked="HighContrastCheckBox_Checked" />

                            <CheckBox
                                x:Name="ReduceAnimationCheckBox"
                                Content="Reduce Animations"
                                Foreground="#E0E0E0"
                                Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- About Section -->
                <StackPanel x:Name="AboutPanel" Visibility="Collapsed">
                    <TextBlock
                        Text="About Monado Blade"
                        Foreground="#00D4FF"
                        FontSize="20"
                        FontWeight="Bold"
                        Margin="0,0,0,20" />

                    <Border Background="#1A1A1A" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <TextBlock Text="Version: " Foreground="#B0B0B0" />
                                <TextBlock Text="2.0.0" Foreground="#00D4FF" FontWeight="Bold" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <TextBlock Text="Build: " Foreground="#B0B0B0" />
                                <TextBlock Text="Phase 8 Stream 3" Foreground="#00D4FF" FontWeight="Bold" />
                            </StackPanel>

                            <TextBlock
                                Text="Copyright © 2024 Monado Project. All rights reserved."
                                Foreground="#808080"
                                FontSize="12"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
