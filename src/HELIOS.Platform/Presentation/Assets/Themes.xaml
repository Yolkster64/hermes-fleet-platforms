<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:HELIOS.Platform.Presentation.Assets">

    <!-- ==================== BRAND COLORS ==================== -->
    
    <!-- Primary Brand Color - Deep Blue -->
    <Color x:Key="PrimaryColor">#1461A5</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    
    <!-- Secondary Accent Color - Vibrant Cyan -->
    <Color x:Key="AccentColor">#00BCD4</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    
    <!-- Semantic Colors for States -->
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    
    <Color x:Key="WarningColor">#FFC107</Color>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    
    <Color x:Key="ErrorColor">#F44336</Color>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    
    <Color x:Key="InfoColor">#2196F3</Color>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    
    <!-- Neutral Colors -->
    <Color x:Key="BackgroundColor">#F5F5F5</Color>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    
    <Color x:Key="TextColor">#212121</Color>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    
    <Color x:Key="SecondaryTextColor">#757575</Color>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}"/>
    
    <Color x:Key="DisabledColor">#BDBDBD</Color>
    <SolidColorBrush x:Key="DisabledBrush" Color="{StaticResource DisabledColor}"/>
    
    <Color x:Key="BorderColor">#E0E0E0</Color>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    
    <!-- ==================== SHADOWS ==================== -->
    
    <system:Double x:Key="ElevationShadow1">0,2,4,0</system:Double>
    <system:Double x:Key="ElevationShadow2">0,4,8,0</system:Double>
    <system:Double x:Key="ElevationShadow3">0,8,16,0</system:Double>
    
    <!-- ==================== SPACING & SIZING ==================== -->
    
    <system:Double x:Key="SpacingXXSmall">4</system:Double>
    <system:Double x:Key="SpacingXSmall">8</system:Double>
    <system:Double x:Key="SpacingSmall">12</system:Double>
    <system:Double x:Key="SpacingMedium">16</system:Double>
    <system:Double x:Key="SpacingLarge">24</system:Double>
    <system:Double x:Key="SpacingXLarge">32</system:Double>
    <system:Double x:Key="SpacingXXLarge">48</system:Double>
    
    <system:Double x:Key="CornerRadiusSmall">4</system:Double>
    <system:Double x:Key="CornerRadiusMedium">8</system:Double>
    <system:Double x:Key="CornerRadiusLarge">12</system:Double>
    
    <!-- ==================== TYPOGRAPHY ==================== -->
    
    <FontFamily x:Key="PrimaryFont">Segoe UI, Tahoma, sans-serif</FontFamily>
    <FontFamily x:Key="MonospaceFont">Consolas, Courier New, monospace</FontFamily>
    
    <system:Double x:Key="FontSizeSmall">12</system:Double>
    <system:Double x:Key="FontSizeBase">13</system:Double>
    <system:Double x:Key="FontSizeMedium">14</system:Double>
    <system:Double x:Key="FontSizeLarge">16</system:Double>
    <system:Double x:Key="FontSizeXLarge">18</system:Double>
    <system:Double x:Key="FontSizeHeading">24</system:Double>
    <system:Double x:Key="FontSizeLargeHeading">32</system:Double>
    
    <!-- ==================== ANIMATION DURATIONS ==================== -->
    
    <system:Double x:Key="AnimationDurationFast">150</system:Double>
    <system:Double x:Key="AnimationDurationNormal">300</system:Double>
    <system:Double x:Key="AnimationDurationSlow">500</system:Double>
    
    <!-- ==================== OPACITY VALUES ==================== -->
    
    <system:Double x:Key="OpacityHover">0.08</system:Double>
    <system:Double x:Key="OpacityPressed">0.12</system:Double>
    <system:Double x:Key="OpacityFocused">0.12</system:Double>
    <system:Double x:Key="OpacityDisabled">0.38</system:Double>

</ResourceDictionary>
