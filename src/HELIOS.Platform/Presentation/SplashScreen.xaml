<Window x:Class="HELIOS.Platform.Presentation.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        ShowInTaskbar="False"
        FocusManager.FocusedElement="{Binding ElementName=root}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Assets/Themes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="root" Width="600" Height="400" Background="Transparent">
        <Border CornerRadius="12" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3"/>
            </Border.Effect>
            
            <Grid>
                <!-- Gradient Background -->
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource PrimaryColor}" Offset="0"/>
                            <GradientStop Color="{StaticResource AccentColor}" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Content -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                    <!-- Logo Area -->
                    <Grid Height="100" HorizontalAlignment="Center">
                        <TextBlock Text="◆" FontSize="80" Foreground="White" 
                                   FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Text="HELIOS" FontSize="32" Foreground="White" 
                                   FontWeight="Bold" VerticalAlignment="Bottom" 
                                   TextAlignment="Center" Margin="0,0,0,-35"/>
                    </Grid>

                    <!-- Title -->
                    <TextBlock Text="HELIOS Platform" FontSize="28" Foreground="White" 
                               FontWeight="SemiBold" TextAlignment="Center" Margin="0,20,0,0"/>

                    <!-- Description -->
                    <TextBlock Text="Advanced AI-Powered Cloud Integration &amp; System Management" 
                               FontSize="14" Foreground="White" TextAlignment="Center" 
                               Opacity="0.9" MaxWidth="500" TextWrapping="Wrap"/>

                    <!-- Loading Bar -->
                    <StackPanel Margin="40,30,40,20">
                        <ProgressBar Height="3" Foreground="{StaticResource AccentBrush}" 
                                     Background="White" Opacity="0.2" IsIndeterminate="True"/>
                        <TextBlock Text="Initializing..." FontSize="12" Foreground="White" 
                                   Opacity="0.7" TextAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Version -->
                    <TextBlock Text="Version 1.0.0" FontSize="11" Foreground="White" 
                               TextAlignment="Center" Opacity="0.6" Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
