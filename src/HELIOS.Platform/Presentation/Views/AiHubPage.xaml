<Page
    x:Class="HELIOS.Platform.Presentation.Views.AiHubPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Enabled"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowSpacing="16" Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="AI Hub" FontSize="32" FontWeight="Bold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
            <TextBlock Text="Manage and deploy AI/ML models" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Content -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Models -->
            <StackPanel Grid.Column="0" Spacing="16">
                <!-- Model Browser -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Available Models" FontSize="16" FontWeight="SemiBold"/>
                            <Button Grid.Column="1" Content="+ Add Model" Click="AddModelButton_Click" Style="{ThemeResource AccentButtonStyle}"/>
                        </Grid>

                        <!-- Search & Filter -->
                        <AutoSuggestBox x:Name="ModelSearchBox" PlaceholderText="Search models..." QuerySubmitted="ModelSearchBox_QuerySubmitted" Width="100" HorizontalAlignment="Stretch"/>

                        <!-- Models List -->
                        <ListView x:Name="ModelsListView" SelectionMode="Single" SelectionChanged="ModelsListView_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12" Padding="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock Text="{Binding Type, StringFormat='Type: {0}'}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                                <TextBlock Text="{Binding Version, StringFormat='v{0}'}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                                <TextBlock Text="{Binding SizeMb, StringFormat='Size: {0} MB'}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="8" Orientation="Horizontal">
                                            <ToggleSwitch x:Name="ModelEnabledToggle" IsOn="{Binding IsEnabled, Mode=TwoWay}" Toggled="ModelEnabledToggle_Toggled"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Model Details -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <StackPanel x:Name="ModelDetailsPanel" Spacing="12">
                        <TextBlock Text="Model Details" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ModelDetailText" Text="Select a model to view details" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <ItemsControl x:Name="ModelMetricsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12" Padding="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right: Actions & Performance -->
            <StackPanel Grid.Column="1" Spacing="16">
                <!-- Quick Actions -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Actions" FontSize="16" FontWeight="SemiBold"/>
                        <Button Content="Refresh Models" Click="RefreshModelsButton_Click" HorizontalAlignment="Stretch"/>
                        <Button Content="Download Model" Click="DownloadModelButton_Click" HorizontalAlignment="Stretch"/>
                        <Button Content="Test Model" Click="TestModelButton_Click" HorizontalAlignment="Stretch"/>
                        <Button Content="Optimize" Click="OptimizeButton_Click" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Model Stats -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Statistics" FontSize="16" FontWeight="SemiBold"/>

                        <StackPanel Spacing="8">
                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Installed Models"/>
                            <TextBlock x:Name="InstalledCountText" Text="0" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Active Models"/>
                            <TextBlock x:Name="ActiveCountText" Text="0" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="GPU Memory Used"/>
                            <TextBlock x:Name="GpuMemoryText" Text="0 MB" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <ProgressBar x:Name="GpuMemoryBar" Maximum="100" Value="0" Height="4"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Inference Speed"/>
                            <TextBlock x:Name="InferenceSpeedText" Text="-- ms" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Recent Activity -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Recent Activity" FontSize="16" FontWeight="SemiBold"/>
                        <ItemsControl x:Name="ActivityLogControl" MaxHeight="150">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="2" Padding="0,4">
                                        <TextBlock Text="{Binding Message}" FontSize="12"/>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='{0:HH:mm:ss}'}" FontSize="10" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
