<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HELIOS.Platform.Presentation.Views.HelpPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HELIOS.Platform.Presentation.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,*" Padding="20">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,20">
            <TextBlock Text="Help & Documentation" Style="{StaticResource HeaderTextBlockStyle}" FontSize="32"/>
            <TextBlock Text="Learn how to use HELIOS Platform effectively" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Content -->
        <ScrollView Grid.Row="1" Padding="0,0,20,0">
            <StackPanel Spacing="20">

                <!-- Getting Started -->
                <StackPanel Spacing="10">
                    <TextBlock Text="Getting Started" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="15" BorderThickness="1" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Welcome to HELIOS Platform!" FontWeight="Bold"/>
                            <TextBlock Text="HELIOS Platform is a comprehensive Windows optimization and management system. Here's how to get started:" TextWrapping="Wrap"/>
                            <BulletList>
                                <ListItem>Use the Dashboard to monitor your system's performance in real-time</ListItem>
                                <ListItem>Access the AI Hub to manage and deploy machine learning models</ListItem>
                                <ListItem>Open the Terminal to execute advanced commands and scripts</ListItem>
                                <ListItem>Use the Tools to access system utilities and optimization features</ListItem>
                                <ListItem>Configure settings to customize the platform for your needs</ListItem>
                            </BulletList>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- FAQ -->
                <StackPanel Spacing="10">
                    <TextBlock Text="Frequently Asked Questions" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="15" BorderThickness="1" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <StackPanel Spacing="15">
                            <StackPanel Spacing="5">
                                <TextBlock Text="How do I use the Dashboard?" FontWeight="Bold"/>
                                <TextBlock Text="The Dashboard displays real-time system metrics. It automatically refreshes every 5 seconds. Click the Refresh button to update manually, or view the Performance button to open Task Manager for detailed analysis." TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <Separator/>

                            <StackPanel Spacing="5">
                                <TextBlock Text="What is the AI Hub?" FontWeight="Bold"/>
                                <TextBlock Text="The AI Hub allows you to manage machine learning models. You can download, enable/disable, test, and optimize models for local or cloud deployment." TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <Separator/>

                            <StackPanel Spacing="5">
                                <TextBlock Text="How do I run Terminal commands?" FontWeight="Bold"/>
                                <TextBlock Text="Type your command in the input field at the bottom and press Enter. Use 'help' to see all available commands. Quick command buttons are available for common operations." TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <Separator/>

                            <StackPanel Spacing="5">
                                <TextBlock Text="Where can I find my logs?" FontWeight="Bold"/>
                                <TextBlock Text="All system logs are stored in the HELIOS configuration directory. You can access them through the Tools section under 'System Diagnostics'." TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Keyboard Shortcuts -->
                <StackPanel Spacing="10">
                    <TextBlock Text="Keyboard Shortcuts" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="15" BorderThickness="1" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <Grid ColumnDefinitions="200,*" ColumnSpacing="20" RowSpacing="8">
                            <TextBlock Text="Ctrl + D" FontFamily="Consolas" FontWeight="Bold"/>
                            <TextBlock Text="Open Dashboard"/>
                            
                            <TextBlock Text="Ctrl + T" FontFamily="Consolas" FontWeight="Bold"/>
                            <TextBlock Text="Open Terminal"/>
                            
                            <TextBlock Text="Ctrl + ," FontFamily="Consolas" FontWeight="Bold"/>
                            <TextBlock Text="Open Settings"/>
                            
                            <TextBlock Text="Ctrl + H" FontFamily="Consolas" FontWeight="Bold"/>
                            <TextBlock Text="Open Help"/>
                            
                            <TextBlock Text="Ctrl + R" FontFamily="Consolas" FontWeight="Bold"/>
                            <TextBlock Text="Refresh current view"/>
                            
                            <TextBlock Text="F1" FontFamily="Consolas" FontWeight="Bold"/>
                            <TextBlock Text="Show help menu"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- System Requirements -->
                <StackPanel Spacing="10">
                    <TextBlock Text="System Requirements" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="15" BorderThickness="1" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="150,*">
                                <TextBlock Text="OS:" FontWeight="Bold"/>
                                <TextBlock Text="Windows 10 or later (Windows 11 recommended)"/>
                            </Grid>
                            <Grid ColumnDefinitions="150,*">
                                <TextBlock Text="RAM:" FontWeight="Bold"/>
                                <TextBlock Text="8 GB minimum (16 GB recommended)"/>
                            </Grid>
                            <Grid ColumnDefinitions="150,*">
                                <TextBlock Text="Disk Space:" FontWeight="Bold"/>
                                <TextBlock Text="2 GB available for installation"/>
                            </Grid>
                            <Grid ColumnDefinitions="150,*">
                                <TextBlock Text=".NET Runtime:" FontWeight="Bold"/>
                                <TextBlock Text=".NET 8.0 or later"/>
                            </Grid>
                            <Grid ColumnDefinitions="150,*">
                                <TextBlock Text="GPU:" FontWeight="Bold"/>
                                <TextBlock Text="Optional (NVIDIA CUDA 12.0+ for GPU acceleration)"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Support -->
                <StackPanel Spacing="10" Margin="0,0,0,30">
                    <TextBlock Text="Support & Contact" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="15" BorderThickness="1" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="For support, documentation, and additional resources:" TextWrapping="Wrap"/>
                            <HyperlinkButton Content="📖 Documentation" NavigateUri="https://github.com/M0nado/helios-platform/wiki"/>
                            <HyperlinkButton Content="🐛 Report Issues" NavigateUri="https://github.com/M0nado/helios-platform/issues"/>
                            <HyperlinkButton Content="💬 Discussion Forum" NavigateUri="https://github.com/M0nado/helios-platform/discussions"/>
                            <HyperlinkButton Content="📧 Contact Us" NavigateUri="mailto:support@helios-platform.dev"/>
                            <TextBlock Text="Version 1.0.0 - Build: April 2026" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,15,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollView>
    </Grid>
</Page>
