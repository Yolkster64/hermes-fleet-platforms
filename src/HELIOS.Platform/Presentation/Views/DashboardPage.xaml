<Page
    x:Class="HELIOS.Platform.Presentation.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Enabled"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowSpacing="16" Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="System Dashboard" FontSize="32" FontWeight="Bold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
            <TextBlock x:Name="LastUpdateText" Text="Last updated: never" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Quick Stats Row -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CPU Usage -->
            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="CPU Usage" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock x:Name="CpuPercentText" Text="0%" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    <ProgressBar x:Name="CpuProgressBar" Value="0" Maximum="100" Height="4"/>
                    <TextBlock x:Name="CpuCoresText" Text="0 cores" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Memory Usage -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Memory" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock x:Name="MemoryPercentText" Text="0%" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    <ProgressBar x:Name="MemoryProgressBar" Value="0" Maximum="100" Height="4"/>
                    <TextBlock x:Name="MemoryUsageText" Text="0 MB / 0 MB" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Disk Usage -->
            <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Disk" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock x:Name="DiskPercentText" Text="0%" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    <ProgressBar x:Name="DiskProgressBar" Value="0" Maximum="100" Height="4"/>
                    <TextBlock x:Name="DiskUsageText" Text="0 MB / 0 MB" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Services Status -->
            <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Services Running" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock x:Name="ServiceCountText" Text="0" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    <ProgressBar x:Name="ServiceProgressBar" Value="0" Maximum="100" Height="4"/>
                    <TextBlock x:Name="ServiceStatusText" Text="0 healthy" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: System Status & Processes -->
            <StackPanel Grid.Column="0" Spacing="16">
                <!-- System Information -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="System Information" FontSize="16" FontWeight="SemiBold"/>
                        <ItemsControl x:Name="SystemInfoControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12" Padding="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" MinWidth="120"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Running Services -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Top Processes" FontSize="16" FontWeight="SemiBold"/>
                        <ListView x:Name="ProcessesListView" MaxHeight="300" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12" Padding="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding ProcessId, StringFormat='PID: {0}'}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Alignment="Right">
                                            <TextBlock Text="{Binding MemoryUsageMb, StringFormat='{0:F1} MB'}" TextAlignment="Right" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding CpuUsagePercent, StringFormat='{0:F1}% CPU'}" TextAlignment="Right" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right: Quick Actions & Health -->
            <StackPanel Grid.Column="1" Spacing="16">
                <!-- Quick Actions -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Quick Actions" FontSize="16" FontWeight="SemiBold"/>
                        <Button Content="Refresh Now" Click="RefreshButton_Click" Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch"/>
                        <Button Content="Open Settings" Click="SettingsButton_Click" HorizontalAlignment="Stretch"/>
                        <Button Content="System Info" Click="SystemInfoButton_Click" HorizontalAlignment="Stretch"/>
                        <Button Content="Performance" Click="PerformanceButton_Click" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Health Status -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="System Health" FontSize="16" FontWeight="SemiBold"/>
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Spacing="4" Orientation="Horizontal">
                                <Ellipse Width="12" Height="12" Fill="Green"/>
                                <TextBlock Text="✓ Overall Healthy" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Spacing="4" Orientation="Horizontal">
                                <Ellipse Width="12" Height="12" Fill="Green"/>
                                <TextBlock Text="✓ Services Running" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Spacing="4" Orientation="Horizontal">
                                <Ellipse Width="12" Height="12" Fill="Green"/>
                                <TextBlock Text="✓ Resources OK" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
